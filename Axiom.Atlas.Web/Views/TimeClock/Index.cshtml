@{
    ViewData["Title"] = "Ponto Eletrônico";
}

@section Styles {
    <link href="~/metronic8/css/fullcalendar.bundle.css" rel="stylesheet" type="text/css" />
    <style>
    #clockCalendar .fc-daygrid-day {
        cursor: pointer;
        transition: background-color .18s ease;
    }

    #clockCalendar .fc-daygrid-day:hover {
        background-color: var(--bs-primary-light);
    }

    #clockCalendar {
        --time-clock-special-surface: rgba(148, 163, 184, .045);
        --time-clock-special-text: #64748b;
        --time-clock-grid-border: rgba(148, 163, 184, .2);
    }

    [data-bs-theme="dark"] #clockCalendar {
        --time-clock-special-surface: rgba(148, 163, 184, .075);
        --time-clock-special-text: #b7c3d5;
        --time-clock-grid-border: rgba(148, 163, 184, .24);
    }

    #clockCalendar .fc-theme-standard td,
    #clockCalendar .fc-theme-standard th {
        border-color: var(--time-clock-grid-border);
    }

    #clockCalendar .fc-daygrid-day.fc-day-sun,
    #clockCalendar .fc-daygrid-day.fc-day-sat,
    #clockCalendar .fc-daygrid-day.time-clock-special-day,
    #clockCalendar .fc-col-header-cell.fc-day-sun,
    #clockCalendar .fc-col-header-cell.fc-day-sat {
        background: var(--time-clock-special-surface);
    }

    #clockCalendar .fc-daygrid-day.fc-day-sun .fc-daygrid-day-number,
    #clockCalendar .fc-daygrid-day.fc-day-sat .fc-daygrid-day-number,
    #clockCalendar .fc-daygrid-day.time-clock-special-day .fc-daygrid-day-number,
    #clockCalendar .fc-col-header-cell.fc-day-sun .fc-col-header-cell-cushion,
    #clockCalendar .fc-col-header-cell.fc-day-sat .fc-col-header-cell-cushion {
        color: var(--time-clock-special-text);
        font-weight: 700;
    }

    #clockCalendar .time-clock-has-absence {
        box-shadow: inset 3px 0 0 var(--bs-success);
    }

    #clockCalendar .time-clock-has-unjustified {
        box-shadow: inset 3px 0 0 var(--bs-danger);
    }

    #clockCalendar .fc-daygrid-day-events {
        min-height: 5.5rem;
    }

    #clockCalendar .fc-daygrid-day-frame {
        position: relative;
        min-height: 100%;
    }

    #clockCalendar .fc-event {
        cursor: pointer;
    }

    #clockCalendar .fc-daygrid-more-link {
        color: var(--bs-primary);
        font-weight: 700;
    }

    #clockCalendar .time-clock-day-indicators {
        position: absolute;
        right: .45rem;
        bottom: .45rem;
        z-index: 3;
        display: inline-flex;
        flex-direction: row-reverse;
        align-items: center;
        gap: .35rem;
    }

    #clockCalendar .time-clock-day-indicator {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.8rem;
        height: 1.8rem;
        border: 1px solid transparent;
        border-radius: .5rem;
        box-shadow: 0 .125rem .35rem rgba(0, 0, 0, .12);
        cursor: help;
    }

    #clockCalendar .time-clock-indicator-medical {
        color: var(--bs-danger);
        background-color: rgba(var(--bs-danger-rgb), .18);
        border-color: rgba(var(--bs-danger-rgb), .45);
    }

    #clockCalendar .time-clock-indicator-warning {
        color: var(--bs-warning);
        background-color: rgba(var(--bs-warning-rgb), .18);
        border-color: rgba(var(--bs-warning-rgb), .45);
    }

    #clockCalendar .time-clock-indicator-primary {
        color: var(--bs-primary);
        background-color: rgba(var(--bs-primary-rgb), .18);
        border-color: rgba(var(--bs-primary-rgb), .45);
    }

    #clockCalendar .time-clock-indicator-success {
        color: var(--bs-success);
        background-color: rgba(var(--bs-success-rgb), .18);
        border-color: rgba(var(--bs-success-rgb), .45);
    }

    #clockCalendar .time-clock-indicator-danger {
        color: var(--bs-danger);
        background-color: rgba(var(--bs-danger-rgb), .18);
        border-color: rgba(var(--bs-danger-rgb), .45);
    }

    .time-clock-month-controls {
        display: grid;
        grid-template-columns: repeat(4, minmax(150px, 1fr));
        gap: .75rem;
        width: min(100%, 760px);
    }

    .time-clock-month-controls .btn,
    .time-clock-month-controls .form-control {
        min-height: 52px;
        white-space: nowrap;
    }

    @@media (max-width: 1199.98px) {
        .time-clock-month-controls {
            grid-template-columns: repeat(2, minmax(180px, 1fr));
        }
    }

    @@media (max-width: 575.98px) {
        .time-clock-month-controls {
            grid-template-columns: 1fr;
            width: 100%;
        }
    }

    .balance-positive {
        color: var(--bs-success);
    }

    .balance-negative {
        color: var(--bs-danger);
    }

    .balance-zero {
        color: var(--bs-gray-600);
    }

    .punch-row {
        border: 1px dashed var(--bs-border-color);
        border-radius: .95rem;
        padding: 1rem;
        background: rgba(255, 255, 255, .02);
    }

    </style>
}

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">
                    @ViewData["Title"]
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-hover-primary">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-500 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Calendário mensal de ponto</li>
                </ul>
            </div>
            <div class="d-flex gap-3">
                <a asp-controller="TimeClock" asp-action="Settings" class="btn btn-sm btn-light-primary">
                    <i class="ki-duotone ki-setting-2 fs-3"><span class="path1"></span><span class="path2"></span></i>
                    Minha jornada
                </a>
                <a asp-controller="TimeClock" asp-action="Audit" class="btn btn-sm btn-light">
                    <i class="ki-duotone ki-chart-simple fs-3"><span class="path1"></span><span class="path2"></span></i>
                    Auditoria
                </a>
            </div>
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            <div class="card mb-5 mb-xl-8">
                <div class="card-body p-8">
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-6">
                        <div>
                            <span class="badge badge-light-primary fw-bold mb-4">Ponto eletrônico</span>
                            <h2 class="text-gray-900 fw-bold mb-3">Controle mensal de ponto</h2>
                            <div class="text-gray-500 fw-semibold fs-6">
                                Clique em um dia para lançar uma ou várias marcações, registrar falta ou anexar uma ausência.
                            </div>
                        </div>
                        <div class="time-clock-month-controls">
                            <button class="btn btn-light d-inline-flex align-items-center justify-content-center gap-2" id="btnPreviousMonth" type="button">
                                <i class="ki-duotone ki-left fs-3"></i><span>Mês anterior</span>
                            </button>
                            <input type="month" id="monthPicker" class="form-control form-control-solid">
                            <button class="btn btn-light d-inline-flex align-items-center justify-content-center gap-2" id="btnNextMonth" type="button">
                                <span>Próximo mês</span><i class="ki-duotone ki-right fs-3"></i>
                            </button>
                            <button class="btn btn-success d-inline-flex align-items-center justify-content-center gap-2" id="btnOpenAbsenceModal" type="button">
                                <i class="ki-duotone ki-plus fs-2"></i><span>Ausência</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-5 g-5 g-xl-8 mb-5 mb-xl-8">
                <div class="col">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5"><span class="symbol-label bg-light-danger"><i class="ki-duotone ki-chart-simple fs-2x text-danger"><span class="path1"></span><span class="path2"></span></i></span></div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold lh-1 ls-n2" id="summaryTotalBalance">0h00</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Banco de horas</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1">Saldo acumulado</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5"><span class="symbol-label bg-light-primary"><i class="ki-duotone ki-wallet fs-2x text-primary"><span class="path1"></span><span class="path2"></span></i></span></div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryBalance">0h00</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Saldo do mês</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1">Calculado até hoje</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5"><span class="symbol-label bg-light-success"><i class="ki-duotone ki-time fs-2x text-success"><span class="path1"></span><span class="path2"></span></i></span></div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryWorked">0h00</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Horas registradas</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1">Lançamentos até hoje</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5"><span class="symbol-label bg-light-info"><i class="ki-duotone ki-calendar-tick fs-2x text-info"><span class="path1"></span><span class="path2"></span></i></span></div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryExpected">0h00</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Horas previstas</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1">Jornada até hoje</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5"><span class="symbol-label bg-light-warning"><i class="ki-duotone ki-shield-tick fs-2x text-warning"><span class="path1"></span><span class="path2"></span></i></span></div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryTolerance">0 min</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Tolerância global</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1">Regra de compensação</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-5 mb-xl-8">
                <div class="card-header border-0 pt-6">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold fs-3" id="calendarTitle">Calendário</span>
                        <span class="text-muted mt-1 fw-semibold fs-7" id="calendarSubtitle">Carregando...</span>
                    </h3>
                    <div class="card-toolbar">
                        <span class="badge badge-light-danger me-2">Sábados e domingos destacados</span>
                        <span class="badge badge-light-success">Ausências não incidem no banco</span>
                    </div>
                </div>
                <div class="card-body pt-0">
                    <div id="clockCalendar" class="py-4">
                        <div class="text-center text-muted py-10">
                            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                            Carregando calendário...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="punchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mw-1000px">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h2 class="fw-bold mb-1">Lançar ponto</h2>
                    <div class="text-muted fw-semibold" id="punchModalDateLabel"></div>
                </div>
                <div class="btn btn-icon btn-sm btn-active-light-primary" data-bs-dismiss="modal">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
            </div>
            <div class="modal-body">
                <div class="alert alert-primary d-flex align-items-center p-5 mb-7">
                    <i class="ki-duotone ki-information-5 fs-2hx text-primary me-4"><span class="path1"></span><span class="path2"></span></i>
                    <div>
                        <div class="fw-bold">Sequência inteligente ativa</div>
                        <div class="text-muted">O botão de adicionar sugere o próximo tipo natural: entrada manhã, saída manhã, entrada tarde e saída tarde.</div>
                    </div>
                </div>

                <div id="punchRows" class="d-flex flex-column gap-4 mb-5"></div>

                <div class="d-flex flex-wrap gap-3 mb-8">
                    <button type="button" class="btn btn-light-primary" id="btnAddPunchRow">
                        <i class="ki-duotone ki-plus fs-2"></i>Adicionar próximo registro
                    </button>
                    <button type="button" class="btn btn-light-danger" id="btnToggleUnjustified">
                        <i class="ki-duotone ki-cross-circle fs-2"><span class="path1"></span><span class="path2"></span></i>Falta sem justificativa
                    </button>
                    <button type="button" class="btn btn-light-danger d-none" id="btnDeleteUnjustified">
                        <i class="ki-duotone ki-trash fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>Remover falta sem justificativa
                    </button>
                </div>

                <div class="card bg-light-danger border border-danger border-dashed mb-8 d-none" id="unjustifiedPanel">
                    <div class="card-body">
                        <h4 class="fw-bold mb-5">Sinalizar falta sem justificativa</h4>
                        <div class="row g-5">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Tipo</label>
                                <select id="unjustifiedType" class="form-select form-select-solid">
                                    <option value="FullDay">Dia todo</option>
                                    <option value="Partial">Parcial</option>
                                </select>
                            </div>
                            <div class="col-md-2 unjustified-partial">
                                <label class="form-label fw-semibold">Início</label>
                                <input type="time" id="unjustifiedStartTime" class="form-control form-control-solid">
                            </div>
                            <div class="col-md-2 unjustified-partial">
                                <label class="form-label fw-semibold">Fim</label>
                                <input type="time" id="unjustifiedEndTime" class="form-control form-control-solid">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Observação</label>
                                <input type="text" id="unjustifiedObservation" class="form-control form-control-solid" placeholder="Opcional">
                            </div>
                        </div>
                        <button type="button" class="btn btn-danger mt-5" id="btnSaveUnjustified">Salvar falta</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-primary" id="btnSavePunches">
                    <i class="ki-duotone ki-check fs-2"></i>Salvar registros
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="absenceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mw-850px">
        <div class="modal-content">
            <form id="absenceForm">
                <div class="modal-header">
                    <div>
                        <h2 class="fw-bold mb-1">Cadastrar ausência</h2>
                        <div class="text-muted fw-semibold">Ausências justificadas reduzem a jornada prevista sem afetar o banco.</div>
                    </div>
                    <div class="btn btn-icon btn-sm btn-active-light-primary" data-bs-dismiss="modal">
                        <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="row g-6">
                        <div class="col-md-6">
                            <label class="required form-label fw-semibold">Tipo</label>
                            <select name="type" id="absenceType" class="form-select form-select-solid" required>
                                <option value="MedicalCertificate">Atestado médico</option>
                                <option value="Vacation">Férias</option>
                                <option value="MaternityLeave">Licença maternidade</option>
                                <option value="MarriageLeave">Casamento</option>
                                <option value="MilitaryService">Alistamento militar</option>
                                <option value="Bereavement">Luto</option>
                                <option value="HomeOffice">Home office</option>
                                <option value="Other">Outra ausência</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="required form-label fw-semibold">Período</label>
                            <select name="periodType" id="absencePeriodType" class="form-select form-select-solid" required>
                                <option value="FullDay">Integral</option>
                                <option value="Partial">Parcial</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="required form-label fw-semibold">Data início</label>
                            <input type="date" name="startDate" id="absenceStartDate" class="form-control form-control-solid" required>
                        </div>
                        <div class="col-md-6">
                            <label class="required form-label fw-semibold">Data fim</label>
                            <input type="date" name="endDate" id="absenceEndDate" class="form-control form-control-solid" required>
                        </div>
                        <div class="col-md-6 absence-partial">
                            <label class="form-label fw-semibold">Hora início</label>
                            <input type="time" name="startTime" id="absenceStartTime" class="form-control form-control-solid">
                        </div>
                        <div class="col-md-6 absence-partial">
                            <label class="form-label fw-semibold">Hora fim</label>
                            <input type="time" name="endTime" id="absenceEndTime" class="form-control form-control-solid">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Observação</label>
                            <textarea name="observation" id="absenceObservation" class="form-control form-control-solid" rows="3" placeholder="Opcional"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Anexos</label>
                            <input type="file" name="files" id="absenceFiles" class="form-control form-control-solid" multiple>
                            <div class="form-text">Aceita imagens, PDFs, documentos e outros comprovantes.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="ki-duotone ki-check fs-2"></i>Salvar ausência
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/metronic8/js/fullcalendar.bundle.js"></script>
    <script>
        const initialYear = @DateTime.Today.Year;
        const initialMonth = @DateTime.Today.Month;
        const punchTypes = [
            { value: 'MorningEntry', label: 'Entrada manhã' },
            { value: 'MorningExit', label: 'Saída manhã' },
            { value: 'AfternoonEntry', label: 'Entrada tarde' },
            { value: 'AfternoonExit', label: 'Saída tarde' }
        ];

        let currentCalendar = null;
        let selectedDate = null;
        let punchModal = null;
        let absenceModal = null;
        let fullCalendar = null;

        document.addEventListener('DOMContentLoaded', () => {
            punchModal = new bootstrap.Modal(document.getElementById('punchModal'));
            absenceModal = new bootstrap.Modal(document.getElementById('absenceModal'));

            const monthPicker = document.getElementById('monthPicker');
            monthPicker.value = `${initialYear}-${String(initialMonth).padStart(2, '0')}`;
            monthPicker.addEventListener('change', () => loadSelectedMonth());

            document.getElementById('btnPreviousMonth').addEventListener('click', () => moveMonth(-1));
            document.getElementById('btnNextMonth').addEventListener('click', () => moveMonth(1));
            document.getElementById('btnOpenAbsenceModal').addEventListener('click', () => openAbsenceModal(selectedDate));
            document.getElementById('btnAddPunchRow').addEventListener('click', addNextPunchRow);
            document.getElementById('btnSavePunches').addEventListener('click', savePunches);
            document.getElementById('btnToggleUnjustified').addEventListener('click', () => {
                document.getElementById('unjustifiedPanel').classList.toggle('d-none');
            });
            document.getElementById('btnSaveUnjustified').addEventListener('click', saveUnjustifiedAbsence);
            document.getElementById('btnDeleteUnjustified').addEventListener('click', deleteUnjustifiedAbsence);
            document.getElementById('unjustifiedType').addEventListener('change', syncUnjustifiedVisibility);
            document.getElementById('absencePeriodType').addEventListener('change', syncAbsenceVisibility);
            document.getElementById('absenceForm').addEventListener('submit', saveAbsence);

            syncUnjustifiedVisibility();
            syncAbsenceVisibility();
            loadSelectedMonth();
        });

        function loadSelectedMonth() {
            const [year, month] = document.getElementById('monthPicker').value.split('-').map(Number);
            loadCalendar(year, month);
        }

        function moveMonth(delta) {
            const picker = document.getElementById('monthPicker');
            const [year, month] = picker.value.split('-').map(Number);
            const date = new Date(year, month - 1 + delta, 1);
            picker.value = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
            loadSelectedMonth();
        }

        async function loadCalendar(year, month) {
            const calendarElement = document.getElementById('clockCalendar');
            if (!fullCalendar) {
                calendarElement.innerHTML = `
                    <div class="text-center text-muted py-10">
                        <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                        Carregando calendário...
                    </div>`;
            }

            try {
                const response = await fetch(`/TimeClock/GetCalendar?year=${year}&month=${month}`);
                currentCalendar = await readJsonResponse(response);
                renderSummary();
                renderCalendar();
            } catch (error) {
                calendarElement.innerHTML = `<div class="text-center text-danger py-10" style="grid-column: 1 / -1;">${escapeHtml(error.message)}</div>`;
            }
        }

        function renderSummary() {
            document.getElementById('calendarTitle').innerText = currentCalendar.monthLabel;
            document.getElementById('calendarSubtitle').innerText = `Jornada padrão: ${currentCalendar.schedule.entryTime} às ${currentCalendar.schedule.exitTime}, intervalo de ${currentCalendar.schedule.lunchIntervalMinutes} min.`;
            document.getElementById('summaryTotalBalance').innerText = currentCalendar.summary.accumulatedBalanceLabel;
            document.getElementById('summaryTotalBalance').className = `fs-2hx fw-bold lh-1 ls-n2 ${getBalanceClass(currentCalendar.summary.accumulatedBalanceMinutes)}`;
            document.getElementById('summaryBalance').innerText = currentCalendar.summary.balanceLabel;
            document.getElementById('summaryBalance').className = `fs-2hx fw-bold lh-1 ls-n2 ${getBalanceClass(currentCalendar.summary.balanceMinutes)}`;
            document.getElementById('summaryWorked').innerText = currentCalendar.summary.workedLabel;
            document.getElementById('summaryExpected').innerText = currentCalendar.summary.expectedLabel;
            document.getElementById('summaryTolerance').innerText = `${currentCalendar.globalSettings.toleranceMinutes} min`;
        }

        function renderCalendar() {
            const calendarElement = document.getElementById('clockCalendar');
            if (typeof FullCalendar === 'undefined') {
                calendarElement.innerHTML = '<div class="text-center text-danger py-10">Não foi possível carregar o calendário.</div>';
                return;
            }

            if (fullCalendar) {
                fullCalendar.destroy();
            }
            calendarElement.innerHTML = '';

            fullCalendar = new FullCalendar.Calendar(calendarElement, {
                initialView: 'dayGridMonth',
                initialDate: `${currentCalendar.year}-${String(currentCalendar.month).padStart(2, '0')}-01`,
                locale: 'pt-br',
                firstDay: 0,
                fixedWeekCount: false,
                selectable: true,
                selectMirror: true,
                dayMaxEvents: 0,
                moreLinkText: count => `+${count} mais`,
                headerToolbar: false,
                dateClick: info => openPunchModal(info.dateStr),
                select: info => {
                    openPunchModal(info.startStr);
                    fullCalendar.unselect();
                },
                eventClick: info => {
                    info.jsEvent.preventDefault();
                    openPunchModal(info.event.extendedProps.date);
                },
                dayCellClassNames: info => getDayClasses(info.date),
                dayCellDidMount: info => renderDayIndicators(info)
            });
            fullCalendar.addEventSource(buildCalendarEvents());
            fullCalendar.render();
        }

        function buildCalendarEvents() {
            return currentCalendar.days.flatMap(day => {
                return day.punches.map(punch => ({
                    title: `${punch.typeLabel} · ${punch.time}`,
                    start: day.date,
                    allDay: true,
                    classNames: ['fc-event-primary'],
                    extendedProps: { date: day.date }
                }));
            });
        }

        function getDayClasses(date) {
            const day = getDay(toDateKey(date));
            const classes = [];

            if (day?.absences.length) classes.push('time-clock-has-absence');
            if (day?.unjustifiedAbsence) classes.push('time-clock-has-unjustified');
            if (day?.isHoliday) classes.push('time-clock-special-day');

            return classes;
        }

        function renderDayIndicators(info) {
            const day = getDay(toDateKey(info.date));
            if (!day) return;

            const indicators = [];
            if (day.isHoliday) {
                indicators.push({ icon: 'ki-calendar-8', theme: 'warning', label: day.holidayName || 'Feriado' });
            }
            if (day.absences.length) {
                [...new Map(day.absences.map(absence => [absence.type, absence])).values()]
                    .forEach(absence => indicators.push(getAbsenceIndicator(absence)));
            }
            if (day.unjustifiedAbsence) {
                indicators.push({ icon: 'ki-information', theme: 'danger', label: day.unjustifiedAbsence.typeLabel });
            }

            if (!indicators.length) return;

            const frame = info.el.querySelector('.fc-daygrid-day-frame');
            if (!frame) return;

            const container = document.createElement('span');
            container.className = 'time-clock-day-indicators';
            container.innerHTML = indicators.map(indicator => `
                <span class="time-clock-day-indicator time-clock-indicator-${indicator.theme}" data-bs-toggle="tooltip" title="${escapeAttribute(indicator.label)}">
                    <i class="ki-duotone ${indicator.icon} fs-4"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                </span>`).join('');
            frame.appendChild(container);

            container.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(element => new bootstrap.Tooltip(element));
        }

        function getAbsenceIndicator(absence) {
            const indicatorsByType = {
                MedicalCertificate: { icon: 'ki-pulse', theme: 'medical' },
                Vacation: { icon: 'ki-airplane', theme: 'primary' },
                MaternityLeave: { icon: 'ki-heart', theme: 'medical' },
                MarriageLeave: { icon: 'ki-people', theme: 'primary' },
                MilitaryService: { icon: 'ki-shield-cross', theme: 'warning' },
                Bereavement: { icon: 'ki-information', theme: 'danger' },
                HomeOffice: { icon: 'ki-home-2', theme: 'success' },
                Other: { icon: 'ki-document', theme: 'primary' }
            };
            const indicator = indicatorsByType[absence.type] || indicatorsByType.Other;

            return {
                ...indicator,
                label: `Ausência: ${absence.typeLabel}`
            };
        }

        function openPunchModal(date) {
            selectedDate = date;
            const day = getDay(date);
            document.getElementById('punchModalDateLabel').innerText = `${formatDatePt(date)} - ${day?.expectedLabel || '0h00'} previstos`;
            document.getElementById('unjustifiedPanel').classList.add('d-none');
            document.getElementById('btnDeleteUnjustified').classList.toggle('d-none', !day?.unjustifiedAbsence);

            const rows = document.getElementById('punchRows');
            rows.innerHTML = '';

            if (day && day.punches.length) {
                day.punches.forEach(punch => addPunchRow(punch));
            } else {
                addPunchRow({ type: day?.nextPunchType || 'MorningEntry', time: '', nsr: '', observation: '' });
            }

            punchModal.show();
        }

        function addNextPunchRow() {
            const usedTypes = getPunchRows().map(row => row.querySelector('.punch-type').value);
            const next = punchTypes.find(type => !usedTypes.includes(type.value));

            if (!next) {
                showMessage('Todos os quatro registros naturais já foram adicionados para este dia.', 'info');
                return;
            }

            addPunchRow({ type: next.value, time: '', nsr: '', observation: '' });
        }

        function addPunchRow(punch) {
            const row = document.createElement('div');
            row.className = 'punch-row';
            row.innerHTML = `
                <div class="row g-4 align-items-end">
                    <div class="col-md-3">
                        <label class="required form-label fw-semibold">Tipo</label>
                        <select class="form-select form-select-solid punch-type">
                            ${punchTypes.map(type => `<option value="${type.value}" ${type.value === punch.type ? 'selected' : ''}>${type.label}</option>`).join('')}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="required form-label fw-semibold">Horário</label>
                        <input type="time" class="form-control form-control-solid punch-time" value="${escapeAttribute(punch.time || '')}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">NSR</label>
                        <input type="text" class="form-control form-control-solid punch-nsr" value="${escapeAttribute(punch.nsr || '')}" inputmode="numeric" maxlength="9" placeholder="9 dígitos">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Observação</label>
                        <input type="text" class="form-control form-control-solid punch-observation" value="${escapeAttribute(punch.observation || '')}" placeholder="Opcional">
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-icon btn-light-danger btn-sm btn-remove-punch" title="Remover">
                            <i class="ki-duotone ki-trash fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        </button>
                    </div>
                </div>`;

            row.querySelector('.btn-remove-punch').addEventListener('click', () => row.remove());
            document.getElementById('punchRows').appendChild(row);
        }

        async function savePunches() {
            const rows = getPunchRows();
            const punches = rows.map(row => ({
                type: row.querySelector('.punch-type').value,
                time: row.querySelector('.punch-time').value,
                nsr: row.querySelector('.punch-nsr').value,
                observation: row.querySelector('.punch-observation').value
            })).filter(punch => punch.type || punch.time);

            const existingPunches = getDay(selectedDate)?.punches || [];
            if (!selectedDate || punches.some(punch => !punch.type || !punch.time)) {
                showMessage('Informe tipo e horário para cada registro de ponto.', 'warning');
                return;
            }

            if (punches.length === 0 && existingPunches.length === 0) {
                showMessage('Inclua ao menos um registro antes de salvar.', 'warning');
                return;
            }

            try {
                const response = await fetch('/TimeClock/SavePunches', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ date: selectedDate, punches })
                });
                await readJsonResponse(response);
                showMessage('Registros de ponto salvos com sucesso.', 'success');
                punchModal.hide();
                loadSelectedMonth();
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        async function saveUnjustifiedAbsence() {
            const type = document.getElementById('unjustifiedType').value;
            const payload = {
                date: selectedDate,
                type,
                startTime: document.getElementById('unjustifiedStartTime').value,
                endTime: document.getElementById('unjustifiedEndTime').value,
                observation: document.getElementById('unjustifiedObservation').value
            };

            try {
                const response = await fetch('/TimeClock/SaveUnjustifiedAbsence', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                await readJsonResponse(response);
                showMessage('Falta sinalizada com sucesso.', 'success');
                punchModal.hide();
                loadSelectedMonth();
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        async function deleteUnjustifiedAbsence() {
            const absence = getDay(selectedDate)?.unjustifiedAbsence;
            if (!absence) return;

            try {
                const response = await fetch(`/TimeClock/DeleteUnjustifiedAbsence/${absence.id}`, { method: 'DELETE' });
                await readJsonResponse(response);
                showMessage('Falta sem justificativa removida.', 'success');
                punchModal.hide();
                loadSelectedMonth();
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        function openAbsenceModal(date) {
            const targetDate = date || document.getElementById('monthPicker').value + '-01';
            document.getElementById('absenceForm').reset();
            document.getElementById('absenceStartDate').value = targetDate;
            document.getElementById('absenceEndDate').value = targetDate;
            syncAbsenceVisibility();
            absenceModal.show();
        }

        async function saveAbsence(event) {
            event.preventDefault();

            const formData = new FormData(document.getElementById('absenceForm'));

            try {
                const response = await fetch('/TimeClock/SaveAbsence', {
                    method: 'POST',
                    body: formData
                });
                await readJsonResponse(response);
                showMessage('Ausência cadastrada com sucesso.', 'success');
                absenceModal.hide();
                loadSelectedMonth();
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        function syncUnjustifiedVisibility() {
            const isPartial = document.getElementById('unjustifiedType').value === 'Partial';
            document.querySelectorAll('.unjustified-partial').forEach(element => element.classList.toggle('d-none', !isPartial));
        }

        function syncAbsenceVisibility() {
            const isPartial = document.getElementById('absencePeriodType').value === 'Partial';
            document.querySelectorAll('.absence-partial').forEach(element => element.classList.toggle('d-none', !isPartial));
        }

        function getPunchRows() {
            return Array.from(document.querySelectorAll('#punchRows .punch-row'));
        }

        function getDay(date) {
            return currentCalendar?.days.find(day => day.date === date);
        }

        function toDateKey(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        async function readJsonResponse(response) {
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
                throw new Error(payload.message || payload.Message || 'Não foi possível concluir a operação.');
            }
            return payload;
        }

        function formatDatePt(date) {
            const [year, month, day] = date.split('-');
            return `${day}/${month}/${year}`;
        }

        function getBalanceClass(minutes) {
            if (minutes > 0) return 'balance-positive';
            if (minutes < 0) return 'balance-negative';
            return 'balance-zero';
        }

        function showMessage(text, icon) {
            if (window.Swal) {
                Swal.fire({
                    text,
                    icon,
                    buttonsStyling: false,
                    confirmButtonText: 'Ok',
                    customClass: { confirmButton: `btn fw-bold btn-${icon === 'error' ? 'danger' : 'primary'}` }
                });
                return;
            }

            alert(text);
        }

        function escapeHtml(value) {
            const element = document.createElement('div');
            element.textContent = value ?? '';
            return element.innerHTML;
        }

        function escapeAttribute(value) {
            return escapeHtml(value).replace(/"/g, '&quot;');
        }
    </script>
}
