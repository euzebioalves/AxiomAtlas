@{
    ViewData["Title"] = "Configurações Globais do Ponto";
}

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">
                    @ViewData["Title"]
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-hover-primary">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <i class="ki-duotone ki-double-right fs-2"></i>
                    </li>
                    <li class="breadcrumb-item text-muted">Tempos</li>
                    <li class="breadcrumb-item">
                        <i class="ki-duotone ki-double-right fs-2"></i>
                    </li>
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="TimeClock" asp-action="Index" class="text-muted text-hover-primary">Ponto Eletrônico</a>
                    </li>
                    <li class="breadcrumb-item">
                        <i class="ki-duotone ki-double-right fs-2"></i>
                    </li>
                    <li class="breadcrumb-item text-muted">Configurações globais</li>
                </ul>
            </div>
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            <div class="card mw-650px">
                <div class="card-header border-0 pt-6">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold fs-3">Tolerância do ponto</span>
                        <span class="text-muted mt-1 fw-semibold fs-7">Apenas administradores podem alterar essa regra.</span>
                    </h3>
                </div>
                <div class="card-body">
                    <form id="globalSettingsForm">
                        <div class="mb-8">
                            <label class="required form-label fw-semibold">Tolerância em minutos</label>
                            <input type="number" id="toleranceMinutes" class="form-control form-control-solid" min="0" max="120" required>
                            <div class="form-text">Diferenças dentro dessa margem são zeradas no banco de horas.</div>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="ki-duotone ki-check fs-2"></i>Salvar tolerância
                        </button>
                        <a asp-controller="TimeClock" asp-action="Index" class="btn btn-light ms-2">Voltar ao calendário</a>
                    </form>
                    <div class="alert alert-warning d-none mt-8" id="adminWarning">
                        Você pode visualizar essa tela, mas a API recusou alteração porque seu usuário não possui perfil de administrador.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadGlobalSettings();
            document.getElementById('globalSettingsForm').addEventListener('submit', saveGlobalSettings);
        });

        async function loadGlobalSettings() {
            try {
                const response = await fetch('/TimeClock/GetGlobalSettings');
                const data = await readJsonResponse(response);
                document.getElementById('toleranceMinutes').value = data.toleranceMinutes;
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        async function saveGlobalSettings(event) {
            event.preventDefault();
            document.getElementById('adminWarning').classList.add('d-none');

            try {
                const response = await fetch('/TimeClock/SaveGlobalSettings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ toleranceMinutes: parseInt(document.getElementById('toleranceMinutes').value) })
                });
                await readJsonResponse(response);
                showMessage('Tolerância salva com sucesso.', 'success');
            } catch (error) {
                if (error.status === 403) {
                    document.getElementById('adminWarning').classList.remove('d-none');
                }
                showMessage(error.message, 'error');
            }
        }

        async function readJsonResponse(response) {
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
                const error = new Error(payload.message || payload.Message || 'Não foi possível concluir a operação.');
                error.status = response.status;
                throw error;
            }
            return payload;
        }

        function showMessage(text, icon) {
            if (window.Swal) {
                Swal.fire({
                    text,
                    icon,
                    buttonsStyling: false,
                    confirmButtonText: 'Ok',
                    customClass: { confirmButton: `btn fw-bold btn-${icon === 'error' ? 'danger' : 'primary'}` }
                });
                return;
            }

            alert(text);
        }
    </script>
}
