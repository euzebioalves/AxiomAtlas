@{
    ViewData["Title"] = "Entradas de Tempo";
}

<style>
    .time-entries-toast-container {
        top: calc(var(--bs-app-header-height, 70px) + 1rem);
        right: 1.5rem;
        width: min(420px, calc(100vw - 2rem));
        z-index: 1095;
    }

    @@media (max-width: 991.98px) {
        .time-entries-toast-container {
            top: 1rem;
            right: 1rem;
        }
    }
</style>

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">
                    @ViewData["Title"]
                </h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-hover-primary"> Home </a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-500 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Apontamento de horas</li>
                </ul>
            </div>
        </div>
    </div>
    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
            <div class="row g-5 g-xl-8 mb-5 mb-xl-8">
                <div class="col-xl-3 col-md-6">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5">
                                <span class="symbol-label bg-light-primary">
                                    <i class="ki-duotone ki-timer fs-2x text-primary"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                                </span>
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryTotalHours">0,00h</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Horas apontadas</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1" id="summaryTotalEntries">0 lançamentos</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5">
                                <span class="symbol-label bg-light-warning">
                                    <i class="ki-duotone ki-time fs-2x text-warning"><span class="path1"></span><span class="path2"></span></i>
                                </span>
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryPendingEntries">0</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Pendentes de sync</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1" id="summaryPendingHours">0,00h</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5">
                                <span class="symbol-label bg-light-success">
                                    <i class="ki-duotone ki-check-circle fs-2x text-success"><span class="path1"></span><span class="path2"></span></i>
                                </span>
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summarySyncedEntries">0</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Sincronizados</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1" id="summarySyncedHours">0,00h</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card card-flush h-xl-100">
                        <div class="card-body d-flex align-items-center p-6">
                            <div class="symbol symbol-50px me-5">
                                <span class="symbol-label bg-light-danger">
                                    <i class="ki-duotone ki-cross-circle fs-2x text-danger"><span class="path1"></span><span class="path2"></span></i>
                                </span>
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fs-2hx fw-bold text-gray-900 lh-1 ls-n2" id="summaryErrorEntries">0</span>
                                <span class="text-gray-600 fw-semibold fs-6 mt-2">Com erro</span>
                                <span class="text-gray-500 fw-semibold fs-7 mt-1" id="summaryErrorHours">0,00h</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card mb-5 mb-xl-8">
                <div class="card-header border-0 pt-5">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bold fs-3 mb-1">Meus Lançamentos</span>
                        <span class="text-muted mt-1 fw-semibold fs-7" id="totalEntriesText">Carregando...</span>
                    </h3>

                    <div class="card-toolbar gap-3">
                        <button type="button" class="btn btn-sm btn-light-success" onclick="syncSelected()">
                            <i class="ki-duotone ki-arrows-circle fs-2"><span class="path1"></span><span class="path2"></span></i>
                            Sincronizar Selecionados
                        </button>
                        <button type="button" class="btn btn-sm btn-primary" id="btnOpenNewModal">
                            <i class="ki-duotone ki-plus fs-2"></i> Novo Apontamento
                        </button>
                    </div>
                </div>
                <div class="card-body py-3">
                    <div class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle gs-0 gy-4">
                            <thead>
                                <tr class="fw-bold text-muted">
                                    <th class="w-25px">
                                        <div class="form-check form-check-sm form-check-custom form-check-solid">
                                            <input class="form-check-input" type="checkbox" id="selectAll">
                                        </div>
                                    </th>
                                    <th class="min-w-100px">Data</th>
                                    <th class="min-w-150px">Work Package</th>
                                    <th class="min-w-200px">Comentário</th>
                                    <th class="min-w-100px">Horas</th>
                                    <th class="min-w-100px">Status</th>
                                    <th class="min-w-130px">OpenProject</th>
                                    <th class="min-w-100px text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody id="entriesTableBody">
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-10">
                                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                                        Buscando lançamentos...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div id="timeEntriesToastHost" class="toast-container position-fixed time-entries-toast-container"></div>

<div class="modal fade" id="timeEntryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered mw-850px">
        <div class="modal-content">
            
            <div class="modal-header pb-0 border-0 justify-content-end">
                <div class="btn btn-sm btn-icon btn-active-color-primary" data-bs-dismiss="modal">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
            </div>
            <div class="modal-body scroll-y px-10 px-lg-15 pt-0 pb-15">
                <form id="timeEntryForm" class="form">
                    <input type="hidden" id="editEntryId" value="">
                    
                    <div class="mb-13 text-center">
                        <h1 class="mb-3" id="modalTitle">Lançar Horas</h1>
                        <div class="text-muted fw-semibold fs-5">
                            Apontamento de atividades no OpenProject
                        </div>
                    </div>
                    <div class="row g-9 mb-8">
                        <div class="col-md-6 fv-row">
                            <label class="required fs-6 fw-semibold mb-2">Work Package</label>
                            <select id="wpId" name="wpId" class="form-select form-select-solid" data-dropdown-parent="#timeEntryModal" data-placeholder="Ex: 10719 ou 'Desenvolvimento'" required>
                                <option></option>
                            </select>
                        </div>
                        <div class="col-md-6 fv-row">
                            <label class="required fs-6 fw-semibold mb-2">Data</label>
                            <input type="date" id="spentOn" class="form-control form-control-solid" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                        </div>
                    </div>
                    <div class="row mb-8">
                        <div class="col-12">
                            <div id="wpTitleHelp" class="form-text mt-0 fs-4" style="display: none;"></div>
                        </div>
                    </div>
                    <div class="d-flex flex-column mb-8 fv-row">
                        <label class="required fs-6 fw-semibold mb-2">Atividade</label>
                        <select id="activityId" class="form-select form-select-solid" data-control="select2" data-hide-search="true" data-placeholder="Selecione a Atividade" required disabled>
                            <option value=""></option>
                        </select>
                    </div>
                    <div class="row g-9 mb-8">
                        <div class="col-md-4 fv-row">
                            <label class="fs-6 fw-semibold mb-2">Início</label>
                            <input type="time" id="startTime" class="form-control form-control-solid time-calc">
                        </div>
                        <div class="col-md-4 fv-row">
                            <label class="fs-6 fw-semibold mb-2">Fim</label>
                            <input type="time" id="endTime" class="form-control form-control-solid time-calc">
                        </div>
                        <div class="col-md-4 fv-row">
                            <label class="required fs-6 fw-semibold mb-2">Total (Horas)</label>
                            <input type="number" step="0.01" id="totalHours" class="form-control form-control-solid bg-light-primary border-primary border border-dashed" placeholder="0.00" required>
                        </div>
                    </div>
                    <div class="d-flex flex-column mb-8">
                        <label class="fs-6 fw-semibold mb-2">Comentário (Opcional)</label>
                        <textarea id="comment" class="form-control form-control-solid" rows="3" placeholder="Descreva o que foi feito..."></textarea>
                    </div>
                    <div class="text-center">
                        <button type="button" class="btn btn-light me-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" id="btnSaveTime" class="btn btn-primary">
                            <span class="indicator-label">Salvar</span>
                            <span class="indicator-progress" style="display: none;">
                                Processando... <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Variável global para armazenar os dados em memória
        let currentEntries = [];

        document.addEventListener("DOMContentLoaded", function () {
            // Carrega a tabela assim que a página abre
            loadTable();
            loadSummary();
            resetActivities('Selecione uma Work Package primeiro');

            document.getElementById('selectAll').addEventListener('change', function () {
                document.querySelectorAll('.row-select:not(:disabled)').forEach(checkbox => {
                    checkbox.checked = this.checked;
                });
            });

            // 1. Lógica para abrir modal de NOVO Apontamento
            document.getElementById('btnOpenNewModal').addEventListener('click', function() {
                document.getElementById('timeEntryForm').reset();
                $('#wpId').val(null).trigger('change');
                
                resetActivities('Selecione uma Work Package primeiro');

                document.getElementById('editEntryId').value = '';
                document.getElementById('modalTitle').innerText = 'Lançar Horas';
                document.querySelector('#btnSaveTime .indicator-label').innerText = 'Salvar Apontamento';
                document.getElementById('wpTitleHelp').style.display = 'none';
                
                const myModal = new bootstrap.Modal(document.getElementById('timeEntryModal'));
                myModal.show();

            // Inicialização do Select2 para buscar Work Packages dinamicamente
            $('#wpId').select2({
                dropdownParent: $('#timeEntryModal'), // Garante que o dropdown abra acima do modal
                minimumInputLength: 3, // Só começa a buscar após digitar 3 caracteres
                language: {
                    inputTooShort: function () { return "Digite 3 ou mais caracteres..."; },
                    noResults: function () { return "Nenhuma Work Package encontrada."; },
                    searching: function () { return "Buscando..."; }
                },
                ajax: {
                    url: '/TimeEntries/SearchWorkPackages', // A nova rota que você vai criar no C#
                    dataType: 'json',
                    delay: 500, // Aguarda meio segundo após parar de digitar para não metralhar a API
                    data: function (params) {
                        return {
                            query: params.term // Envia o que o usuário digitou como "?query=texto"
                        };
                    },
                    processResults: function (data) {
                        // O Select2 espera um array com "id" e "text".
                        // Vamos mapear o retorno da sua API para esse formato.
                        return {
                            results: data.map(function (wp) {
                                return {
                                    id: wp.id, // O ID da WP (ex: 10719)
                                    text: `#${wp.id} - ${wp.subject}` // O texto que aparece na lista
                                };
                            })
                        };
                    }
                }
            });

            // EVENTO: Quando o usuário seleciona uma WP no Select2
            $('#wpId').on('select2:select', function (e) {
                // Pegamos os dados do item que acabou de ser clicado
                const selectedData = e.params.data;
                const wpHelp = document.getElementById('wpTitleHelp');
    
                // Mostramos a div da legenda (que ocupa a col-12)
                wpHelp.style.display = 'block';
                wpHelp.className = 'form-text text-success mt-1 fs-6';
    
                // Injetamos o texto completo com o ícone de check do Metronic
                wpHelp.innerHTML = `<i class="ki-duotone ki-check-circle fs-3 text-success"><span class="path1"></span><span class="path2"></span></i> <strong>Selecionado:</strong> ${selectedData.text}`;

                loadActivities(selectedData.id);
            });

            // EVENTO: Quando o campo for limpo (se houver botão de clear) ou resetado
            $('#wpId').on('change', function () {
                if (!this.value) {
                    document.getElementById('wpTitleHelp').style.display = 'none';
                    resetActivities('Selecione uma Work Package primeiro');
                }
            });
            });

            // 2. Cálculo automático de horas
            const startTimeInput = document.getElementById('startTime');
            const endTimeInput = document.getElementById('endTime');
            const totalHoursInput = document.getElementById('totalHours');

            function calculateHours() {
                const start = startTimeInput.value;
                const end = endTimeInput.value;

                if (start && end) {
                    const startDate = new Date(`1970-01-01T${start}:00`);
                    let endDate = new Date(`1970-01-01T${end}:00`);

                    if (endDate < startDate) endDate.setDate(endDate.getDate() + 1);

                    const diffHrs = (endDate - startDate) / (1000 * 60 * 60);
                    totalHoursInput.value = diffHrs.toFixed(2);
                }
            }
            startTimeInput.addEventListener('change', calculateHours);
            endTimeInput.addEventListener('change', calculateHours);

            // 3. Busca de Work Package Info (Feedback visual)
            document.getElementById('wpId').addEventListener('blur', async function () {
                const wpId = this.value;
                if (!wpId) return;
                
                const wpHelp = document.getElementById('wpTitleHelp');
                wpHelp.style.display = 'block';
                wpHelp.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Buscando...';

                try {
                    const response = await fetch(`/TimeEntries/GetWorkPackageInfo?wpId=${wpId}`);
                    if (response.ok) {
                        const data = await response.json();
                        wpHelp.className = 'form-text text-success mt-1';
                        wpHelp.innerHTML = `<i class="ki-duotone ki-check-circle fs-3 text-success"></i> <strong>${data.projectName}:</strong> ${data.subject}`;
                    } else {
                        wpHelp.className = 'form-text text-danger mt-1';
                        wpHelp.innerHTML = `<i class="ki-duotone ki-cross-circle fs-3 text-danger"></i> Não encontrado.`;
                    }
                } catch (e) {
                    wpHelp.style.display = 'none';
                }
            });

            // 4. SUBMIT DO FORMULÁRIO (Novo ou Editar)
            document.getElementById('timeEntryForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const btnSave = document.getElementById('btnSaveTime');
                const editId = document.getElementById('editEntryId').value;
                
                const payload = {
                    WorkPackageId: parseInt(document.getElementById('wpId').value),
                    SpentOn: document.getElementById('spentOn').value,
                    Hours: parseFloat(document.getElementById('totalHours').value),
                    ActivityId: parseInt(document.getElementById('activityId').value),
                    Comment: document.getElementById('comment').value,
                    StartTime: document.getElementById('startTime').value,
                    EndTime: document.getElementById('endTime').value
                };

                const url = editId ? `/TimeEntries/Update/${editId}` : '/TimeEntries/LogTime';
                const method = editId ? 'PUT' : 'POST';

                btnSave.setAttribute('data-kt-indicator', 'on');
                btnSave.disabled = true;

                try {
                    const response = await fetch(url, {
                        method: method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        bootstrap.Modal.getInstance(document.getElementById('timeEntryModal')).hide();
                        loadTable(); // Recarrega a tabela imediatamente
                        loadSummary();
                        showPageToast(
                            'success',
                            editId ? 'Apontamento atualizado' : 'Apontamento criado',
                            editId ? 'As alterações foram salvas com sucesso.' : 'O lançamento foi salvo e já aparece na listagem.'
                        );
                    } else {
                        const err = await response.json();
                        showPageToast('danger', 'Não foi possível salvar', err.message || 'Erro na operação.', 7000);
                    }
                } catch (error) {
                    showPageToast('danger', 'Erro de conexão', 'Não foi possível comunicar com o servidor.', 7000);
                } finally {
                    btnSave.removeAttribute('data-kt-indicator');
                    btnSave.disabled = false;
                }
            });
        });

        // 5. FUNÇÃO PARA BUSCAR E RENDERIZAR A TABELA
        async function loadSummary() {
            try {
                const response = await fetch('/TimeEntries/GetSummary');
                if (!response.ok) return;

                const summary = await response.json();
                document.getElementById('summaryTotalHours').innerText = `${formatHours(summary.totalHours)}h`;
                document.getElementById('summaryTotalEntries').innerText = `${summary.totalEntries || 0} lançamentos`;
                document.getElementById('summaryPendingEntries').innerText = summary.pendingEntries || 0;
                document.getElementById('summaryPendingHours').innerText = `${formatHours(summary.pendingHours)}h`;
                document.getElementById('summarySyncedEntries').innerText = summary.syncedEntries || 0;
                document.getElementById('summarySyncedHours').innerText = `${formatHours(summary.syncedHours)}h`;
                document.getElementById('summaryErrorEntries').innerText = summary.errorEntries || 0;
                document.getElementById('summaryErrorHours').innerText = `${formatHours(summary.errorHours)}h`;
            } catch (error) {
                console.warn("Não foi possível carregar o resumo dos apontamentos:", error);
            }
        }

        function formatHours(value) {
            return Number(value || 0).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function resetActivities(placeholder) {
            const activitySelect = document.getElementById('activityId');
            activitySelect.innerHTML = `<option value="">${placeholder}</option>`;
            activitySelect.disabled = true;
            $('#activityId').prop('disabled', true).val('').trigger('change.select2');
        }

        function setActivitiesLoading() {
            const activitySelect = document.getElementById('activityId');
            activitySelect.innerHTML = '<option value="">Carregando atividades...</option>';
            activitySelect.disabled = true;
            $('#activityId').prop('disabled', true).val('').trigger('change.select2');
        }

        async function loadActivities(workPackageId, selectedActivityId) {
            if (!workPackageId) {
                resetActivities('Selecione uma Work Package primeiro');
                return;
            }

            setActivitiesLoading();

            try {
                const response = await fetch(`/TimeEntries/GetActivities?workPackageId=${encodeURIComponent(workPackageId)}`);
                if (!response.ok) {
                    resetActivities('Não foi possível carregar atividades');
                    return;
                }

                const activities = await response.json();
                if (!Array.isArray(activities) || activities.length === 0) {
                    resetActivities('Nenhuma atividade disponível para esta Work Package');
                    return;
                }

                const activitySelect = document.getElementById('activityId');
                activitySelect.innerHTML = '<option value=""></option>';
                activitySelect.disabled = false;
                $('#activityId').prop('disabled', false);

                activities.forEach(activity => {
                    const option = document.createElement('option');
                    option.value = activity.id;
                    option.textContent = activity.name;
                    activitySelect.appendChild(option);
                });

                const targetValue = selectedActivityId
                    || activities.find(activity => activity.isDefault)?.id
                    || '';

                if (targetValue) {
                    activitySelect.value = String(targetValue);
                }

                $('#activityId').trigger('change.select2');
            } catch (error) {
                console.warn("Não foi possível carregar as atividades do OpenProject:", error);
                resetActivities('Erro ao carregar atividades');
            }
        }

        function getSyncStatus(syncStatus) {
            const normalizedStatus = String(syncStatus).toLowerCase();

            if (normalizedStatus === '1' || normalizedStatus === 'synced') {
                return { label: 'Sincronizado', badgeClass: 'badge badge-light-success fs-7 fw-bold' };
            }

            if (normalizedStatus === '2' || normalizedStatus === 'error') {
                return { label: 'Erro', badgeClass: 'badge badge-light-danger fs-7 fw-bold' };
            }

            return { label: 'Pendente', badgeClass: 'badge badge-light-warning fs-7 fw-bold' };
        }

        function escapeHtml(value) {
            const element = document.createElement('div');
            element.textContent = value ?? '';
            return element.innerHTML;
        }

        function escapeAttribute(value) {
            return escapeHtml(value).replace(/"/g, '&quot;');
        }

        function getToastConfig(type) {
            const configs = {
                success: {
                    borderClass: 'border-success',
                    textClass: 'text-success',
                    icon: 'ki-check-circle'
                },
                warning: {
                    borderClass: 'border-warning',
                    textClass: 'text-warning',
                    icon: 'ki-information-5'
                },
                danger: {
                    borderClass: 'border-danger',
                    textClass: 'text-danger',
                    icon: 'ki-cross-circle'
                },
                info: {
                    borderClass: 'border-primary',
                    textClass: 'text-primary',
                    icon: 'ki-information-5'
                }
            };

            return configs[type] || configs.info;
        }

        function showPageToast(type, title, message, autoCloseMs = 4500) {
            const host = document.getElementById('timeEntriesToastHost');
            if (!host) return;

            const config = getToastConfig(type);
            const toastId = `time-entry-toast-${Date.now()}`;
            const messageHtml = escapeHtml(message || '').replace(/\n/g, '<br>');
            const delay = autoCloseMs > 0 ? autoCloseMs : 5000;

            host.insertAdjacentHTML('afterbegin', `
                <div id="${toastId}" class="toast bg-body border-start border-4 ${config.borderClass} shadow-sm" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header border-0 pb-0">
                        <i class="ki-duotone ${config.icon} fs-2 ${config.textClass} me-3"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        <strong class="me-auto text-gray-900">${escapeHtml(title || 'Aviso')}</strong>
                        <small class="text-muted">agora</small>
                        <button type="button" class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="toast" aria-label="Fechar">
                            <i class="ki-duotone ki-cross fs-2 ${config.textClass}"><span class="path1"></span><span class="path2"></span></i>
                        </button>
                    </div>
                    <div class="toast-body pt-2 fw-semibold text-gray-700">
                        ${messageHtml}
                    </div>
                </div>`);

            const toastElement = document.getElementById(toastId);
            if (!toastElement) return;

            const stackedToasts = Array.from(host.querySelectorAll('.toast'));
            stackedToasts.slice(3).forEach(toast => toast.remove());

            toastElement.addEventListener('hidden.bs.toast', () => toastElement.remove());

            if (window.bootstrap?.Toast) {
                bootstrap.Toast.getOrCreateInstance(toastElement, {
                    autohide: autoCloseMs > 0,
                    delay
                }).show();
                return;
            }

            toastElement.classList.add('show');
            if (autoCloseMs > 0) {
                setTimeout(() => toastElement.remove(), delay);
            }
        }

        function isSyncedEntry(entry) {
            const normalizedStatus = String(entry.syncStatus).toLowerCase();
            return normalizedStatus === '1' || normalizedStatus === 'synced';
        }

        function renderWorkPackageCell(entry) {
            const label = `#${entry.workPackageId}`;
            const title = entry.workPackageSubject
                ? `${label} - ${entry.workPackageSubject}`
                : label;
            const link = entry.workPackageUrl
                ? `<a href="${escapeAttribute(entry.workPackageUrl)}" target="_blank" rel="noopener noreferrer" class="text-primary fw-bold text-hover-primary d-inline-flex align-items-center gap-1 fs-6" title="Abrir ${escapeAttribute(title)} no OpenProject">${label}<i class="ki-duotone ki-exit-up fs-7"></i></a>`
                : `<span class="text-gray-900 fw-bold d-block fs-6">${label}</span>`;
            const subject = entry.workPackageSubject
                ? `<span class="text-muted fw-semibold d-block fs-8 mt-1">${escapeHtml(entry.workPackageSubject)}</span>`
                : '';
            const project = entry.workPackageProjectName
                ? `<span class="badge badge-light fs-8 fw-semibold mt-1 align-self-start">${escapeHtml(entry.workPackageProjectName)}</span>`
                : '';

            return `<div class="d-flex flex-column">${link}${subject}${project}</div>`;
        }

        function renderOpenProjectEntryCell(entry) {
            if (entry.openProjectTimeEntryId) {
                const label = `OP #${entry.openProjectTimeEntryId}`;
                return entry.openProjectTimeEntryUrl
                    ? `<a href="${escapeAttribute(entry.openProjectTimeEntryUrl)}" target="_blank" rel="noopener noreferrer" class="badge badge-light-success fw-bold" title="Abrir apontamento no relatório de tempo/custos do OpenProject">${label}<i class="ki-duotone ki-exit-up fs-8 ms-1"></i></a>`
                    : `<span class="badge badge-light-success fw-bold">${label}</span>`;
            }

            if (entry.syncErrorMessage) {
                return `<span class="badge badge-light-danger fw-bold" title="${escapeAttribute(entry.syncErrorMessage)}">Ver erro</span>`;
            }

            return '<span class="text-muted fw-semibold fs-8">Aguardando sync</span>';
        }

        function renderActionButtons(entry) {
            const locked = entry.canEdit === false || entry.canDelete === false || isSyncedEntry(entry);
            const lockAction = `showLockedEntryMessage('${entry.id}')`;
            const editAction = locked ? lockAction : `editEntry('${entry.id}')`;
            const deleteAction = locked ? lockAction : `deleteEntry('${entry.id}')`;
            const lockedTitle = escapeAttribute(entry.lockReason || 'Este apontamento está bloqueado para alterações locais.');
            const editTitle = locked ? lockedTitle : 'Editar';
            const deleteTitle = locked ? lockedTitle : 'Excluir';
            const lockedClass = locked ? 'btn-active-color-warning opacity-75' : 'btn-active-color-primary';
            const deleteClass = locked ? 'btn-active-color-warning opacity-75' : 'btn-active-color-danger';

            return `
                <button onclick="${editAction}" class="btn btn-icon btn-bg-light ${lockedClass} btn-sm me-1" title="${editTitle}">
                    <i class="ki-duotone ki-pencil fs-2"><span class="path1"></span><span class="path2"></span></i>
                </button>
                <button onclick="${deleteAction}" class="btn btn-icon btn-bg-light ${deleteClass} btn-sm" title="${deleteTitle}">
                    <i class="ki-duotone ki-trash fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span></i>
                </button>`;
        }

        function showLockedEntryMessage(id) {
            const entry = currentEntries.find(e => e.id === id);
            showPageToast(
                'info',
                'Apontamento bloqueado',
                entry?.lockReason || 'Este apontamento já foi sincronizado com o OpenProject e está bloqueado para alterações locais.',
                6500
            );
        }

        async function loadTable() {
            try {
                const response = await fetch('/TimeEntries/GetEntries');
                if (response.ok) {
                    currentEntries = await response.json();
                    const tbody = document.getElementById('entriesTableBody');
                    tbody.innerHTML = '';
                    document.getElementById('selectAll').checked = false;

                    document.getElementById('totalEntriesText').innerText = `${currentEntries.length} lançamentos encontrados`;

                    if (currentEntries.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-10">Nenhum apontamento pendente.</td></tr>`;
                        return;
                    }

                    currentEntries.forEach(entry => {
                        const dataFmt = new Date(entry.spentOn).toLocaleDateString('pt-BR');
                        const status = getSyncStatus(entry.syncStatus);
                        const statusTitle = entry.syncErrorMessage ? ` title="${escapeAttribute(entry.syncErrorMessage)}"` : '';
                        const safeComment = escapeHtml(entry.comment || '-');
                        const isSynced = isSyncedEntry(entry);
                        const selectTitle = isSynced
                            ? 'Este apontamento já foi sincronizado.'
                            : 'Selecionar para sincronizar';
                        const selectDisabled = isSynced ? 'disabled' : '';
                        const row = `
                            <tr>
                                <td>
                                    <div class="form-check form-check-sm form-check-custom form-check-solid">
                                        <input class="form-check-input row-select" type="checkbox" value="${entry.id}" title="${selectTitle}" ${selectDisabled}>
                                    </div>
                                </td>
                                <td><span class="text-gray-900 fw-bold d-block fs-6">${dataFmt}</span></td>
                                <td>${renderWorkPackageCell(entry)}</td>
                                <td><span class="text-muted fw-semibold d-block fs-7">${safeComment}</span></td>
                                <td><span class="badge badge-light-primary fs-7 fw-bold">${entry.hours.toFixed(2)}h</span></td>
                                <td><span class="${status.badgeClass}"${statusTitle}>${status.label}</span></td>
                                <td>${renderOpenProjectEntryCell(entry)}</td>
                                <td class="text-end">${renderActionButtons(entry)}</td>
                            </tr>`;
                        tbody.innerHTML += row;
                    });
                }
            } catch (error) {
                console.error("Erro ao carregar tabela:", error);
                document.getElementById('entriesTableBody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-10">Erro ao carregar dados.</td></tr>`;
            }
        }

        // 6. FUNÇÃO DE EDITAR
        function editEntry(id) {
            const entry = currentEntries.find(e => e.id === id);
            if (!entry) return;
            if (entry.canEdit === false || isSyncedEntry(entry)) {
                showLockedEntryMessage(id);
                return;
            }

            document.getElementById('editEntryId').value = entry.id;
            const wpOption = new Option(`#${entry.workPackageId}`, entry.workPackageId, true, true);
            $('#wpId').append(wpOption).trigger('change');
            document.getElementById('spentOn').value = entry.spentOn.split('T')[0];
            
            loadActivities(entry.workPackageId, entry.activityId);
            
            document.getElementById('comment').value = entry.comment || '';
            document.getElementById('totalHours').value = entry.hours.toFixed(2);
            
            if (entry.startTime) document.getElementById('startTime').value = entry.startTime.substring(0, 5);
            else document.getElementById('startTime').value = "";

            if (entry.endTime) document.getElementById('endTime').value = entry.endTime.substring(0, 5);
            else document.getElementById('endTime').value = "";

            document.getElementById('modalTitle').innerText = 'Editar Apontamento';
            document.querySelector('#btnSaveTime .indicator-label').innerText = 'Salvar Alterações';
            
            const myModal = new bootstrap.Modal(document.getElementById('timeEntryModal'));
            myModal.show();
        }

        // 7. FUNÇÃO DE EXCLUIR (Com SweetAlert2 Padrão Metronic)
        function deleteEntry(id) {
            const entry = currentEntries.find(e => e.id === id);
            if (entry?.canDelete === false || isSyncedEntry(entry || {})) {
                showLockedEntryMessage(id);
                return;
            }

            Swal.fire({
                text: "Deseja realmente excluir este lançamento?",
                icon: "warning",
                showCancelButton: true,
                buttonsStyling: false,
                confirmButtonText: "Sim, excluir!",
                cancelButtonText: "Não, cancelar",
                customClass: {
                    confirmButton: "btn fw-bold btn-danger",
                    cancelButton: "btn fw-bold btn-active-light-primary"
                }
            }).then(async function (result) {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch(`/TimeEntries/Delete/${id}`, { method: 'DELETE' });
                        
                        if (response.ok) {
                            loadTable(); // Recarrega a tabela para sumir com o registro
                            loadSummary();
                            showPageToast('success', 'Lançamento excluído', 'O apontamento foi removido com sucesso.');
                        } else {
                            showPageToast('danger', 'Erro ao excluir', 'Desculpe, ocorreu um erro no servidor ao tentar excluir.', 7000);
                        }
                    } catch (error) {
                        showPageToast('danger', 'Erro de comunicação', 'Não foi possível comunicar com o servidor.', 7000);
                    }
                }
            });
        }

        // 8. FUNÇÃO DE SINCRONIZAR
        async function syncSelected() {
            const selectedIds = Array.from(document.querySelectorAll('.row-select:checked')).map(cb => cb.value);
            
            if (selectedIds.length === 0) {
                showPageToast('warning', 'Nada selecionado', 'Selecione pelo menos um apontamento para sincronizar.');
                return;
            }
            
            try {
                Swal.fire({
                    text: "Sincronizando apontamentos...",
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                const response = await fetch('/TimeEntries/SyncEntries', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(selectedIds)
                });

                const data = await response.json().catch(() => ({
                    message: 'Não foi possível ler a resposta do servidor.'
                }));

                if (response.ok) {
                    Swal.close();
                    showPageToast('success', 'Sincronização concluída', data.message || 'Apontamentos sincronizados com sucesso.');
                    loadTable();
                    loadSummary();
                } else {
                    const details = Array.isArray(data.errors) && data.errors.length > 0
                        ? data.errors.slice(0, 3).join('\n')
                        : data.message || 'Erro ao tentar sincronizar.';

                    Swal.close();
                    showPageToast('danger', 'Erro na sincronização', details, 8000);
                    loadTable();
                    loadSummary();
                }
            } catch (error) {
                Swal.close();
                showPageToast('danger', 'Erro de conexão', 'Não foi possível comunicar com o servidor.', 7000);
            }
        }
    </script>
}
