@using System.Reflection
@{
    // A versao informativa inclui o hash do commit quando o projeto esta em um repositorio Git.
    // O rodape deve apresentar somente a versao publicada do produto.
    var version = Assembly.GetEntryAssembly()?
        .GetName()
        .Version?
        .ToString(3);

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var profilePictureClaim = User?.FindFirst("ProfilePictureUrl")?.Value;
    var profilePictureUrl = string.IsNullOrWhiteSpace(profilePictureClaim)
        ? Url.Content("~/metronic8/images/unknown-user.png")
        : Url.Content(profilePictureClaim);
    var userName = User?.Identity?.Name ?? "Usuário";
    var jobTitle = User?.FindFirst("JobTitle")?.Value ?? "Axiom Atlas";

    string Active(string controller, string action = "")
    {
        return currentController == controller && (string.IsNullOrEmpty(action) || currentAction == action)
            ? "active"
            : "";
    }

    string Open(params string[] controllers)
    {
        return Array.IndexOf(controllers, currentController) >= 0 ? "here show" : "";
    }
}

<!doctype html>
<html lang="pt-br" data-bs-theme="light">
<head>
    <title>@ViewData["Title"] - Axiom Atlas</title>
    <meta charset="utf-8" />
    <meta name="description" content="Axiom Atlas - Gestão de apontamentos, ponto eletrônico, auditoria e integrações corporativas." />
    <meta name="keywords" content="Axiom Atlas, apontamento de horas, ponto eletrônico, OpenProject, auditoria" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:locale" content="pt-BR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Axiom Atlas" />
    <meta property="og:site_name" content="Axiom Atlas" />
    <link rel="shortcut icon" href="~/favicon.ico" />

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" />
    <link href="~/metronic8/css/datatables.bundle.css" rel="stylesheet" type="text/css" />
