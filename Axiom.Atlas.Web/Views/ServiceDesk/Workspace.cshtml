@using System.Net
@using System.Text.Json
@using System.Text.RegularExpressions
@model Axiom.Atlas.Application.DTOs.ServiceDesk.GlpiTicketWorkspaceDto
@{
    ViewData["Title"] = $"GLPI #{Model.GlpiTicketId}";
    using var ticket = JsonDocument.Parse(Model.TicketPayloadJson);
    var payload = ticket.RootElement;
    string Text(string name) => payload.TryGetProperty(name, out var value) ? value.ToString() : string.Empty;
    var rawDescription = Text("content");
    var description = WebUtility.HtmlDecode(rawDescription);
    // O GLPI pode armazenar HTML no conteúdo; removemos apenas vetores executáveis antes da renderização.
    description = Regex.Replace(description, @"<(script|style|iframe|object|embed)[^>]*>.*?</\1>", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"\son\w+\s*=\s*[^\s>]+", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"javascript\s*:", string.Empty, RegexOptions.IgnoreCase);
    var descriptionDocument = $"<!doctype html><html><head><base target='_blank'><style>html,body{{background:#1e1e2d!important;color:#e1e3ea!important}}body{{margin:0;padding:1rem;font-family:Inter,Arial,sans-serif;line-height:1.65;overflow-wrap:anywhere}}img{{max-width:100%!important;height:auto!important;border-radius:.45rem}}table{{max-width:100%!important;border-collapse:collapse}}td,th{{padding:.35rem}}a{{color:#50cdff!important}}hr{{border-color:#393945}}</style></head><body>{description}</body></html>";
    var status = Text("status");
    var createdAt = Text("date");
    var updatedAt = Text("date_mod");
    using var followUps = JsonDocument.Parse(Model.FollowUpsJson);
    using var attachments = JsonDocument.Parse(Model.AttachmentsJson);
    var followUpCount = followUps.RootElement.ValueKind == JsonValueKind.Array ? followUps.RootElement.GetArrayLength() : 0;
    var attachmentCount = attachments.RootElement.ValueKind == JsonValueKind.Array ? attachments.RootElement.GetArrayLength() : 0;
}
<div class="app-content flex-column-fluid"><div class="app-container container-xxl"><div class="d-flex flex-wrap flex-stack mb-7"><div><div class="text-muted fs-7">GLPI #@Model.GlpiTicketId · @(Model.ClientEntityName ?? "Entidade não identificada")</div><h1 class="fs-2 fw-bold">@Model.Subject</h1></div><a asp-action="Index" class="btn btn-light-primary">Nova importação</a></div>
<div class="row g-7"><div class="col-xl-5"><div class="card card-flush h-100"><div class="card-header"><h3 class="card-title">Dossiê do chamado</h3></div><div class="card-body"><div class="d-flex flex-wrap gap-2 mb-6"><span class="badge badge-light-primary">@(Model.EntityPath ?? "Sem entidade")</span><span class="badge badge-light-info">Status GLPI: @status</span></div><div class="border border-dashed rounded p-5 mb-5 glpi-ticket-content"><div class="fw-bold mb-4">Descrição do chamado</div>@if (string.IsNullOrWhiteSpace(description)) { <div class="text-muted">O GLPI não retornou uma descrição para este chamado.</div> } else { <iframe class="glpi-ticket-frame" sandbox="allow-same-origin" srcdoc="@descriptionDocument" title="Conteúdo do chamado GLPI"></iframe> }</div><div class="row g-4"><div class="col-6"><div class="text-muted fs-8">Criado em</div><div class="fw-semibold">@createdAt</div></div><div class="col-6"><div class="text-muted fs-8">Atualizado em</div><div class="fw-semibold">@updatedAt</div></div><div class="col-6"><div class="text-muted fs-8">Acompanhamentos</div><div class="fw-bold fs-4">@followUpCount</div></div><div class="col-6"><div class="text-muted fs-8">Anexos</div><div class="fw-bold fs-4">@attachmentCount</div></div></div></div></div></div>
<div class="col-xl-7"><div class="card card-flush"><div class="card-header"><h3 class="card-title">User Story em Markdown</h3><div class="card-toolbar"><button id="saveDraft" class="btn btn-primary">Salvar rascunho</button></div></div><div class="card-body"><textarea id="draft" class="form-control form-control-solid font-monospace" rows="20" placeholder="# User Story&#10;&#10;## Contexto&#10;## Critérios de aceite">@Model.RequirementMarkdown</textarea><div class="form-text">Use Markdown. Imagens coladas serão incluídas como referência na próxima etapa de anexos.</div></div></div></div></div></div></div>
@section Scripts { <script>document.getElementById('saveDraft').onclick=async()=>{const r=await fetch('/ServiceDesk/SaveDraft/@Model.Id',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requirementMarkdown:document.getElementById('draft').value})});Swal.fire({icon:r.ok?'success':'error',text:r.ok?'Rascunho salvo com sucesso.':'Não foi possível salvar o rascunho.'});};document.querySelectorAll('.glpi-ticket-frame').forEach(frame=>frame.addEventListener('load',()=>{const body=frame.contentDocument?.body;if(body)frame.style.height=`${Math.min(Math.max(body.scrollHeight+8,260),720)}px`;}));</script> }
<style>.glpi-ticket-content{background:var(--bs-gray-100)}.glpi-ticket-frame{display:block;width:100%;min-height:260px;border:1px solid var(--bs-gray-700);background:#1e1e2d;border-radius:.475rem}</style>
