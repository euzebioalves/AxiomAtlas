@model Axiom.Atlas.Application.DTOs.ServiceDesk.GlpiTicketWorkspaceDto
@{ ViewData["Title"] = $"GLPI #{Model.GlpiTicketId}"; }
<div class="app-content flex-column-fluid"><div class="app-container container-xxl"><div class="d-flex flex-wrap flex-stack mb-7"><div><div class="text-muted fs-7">GLPI #@Model.GlpiTicketId · @(Model.ClientEntityName ?? "Entidade não identificada")</div><h1 class="fs-2 fw-bold">@Model.Subject</h1></div><a asp-action="Index" class="btn btn-light-primary">Nova importação</a></div>
<div class="row g-7"><div class="col-xl-5"><div class="card card-flush h-100"><div class="card-header"><h3 class="card-title">Dossiê do chamado</h3></div><div class="card-body"><div class="mb-5"><span class="badge badge-light-info">@(Model.EntityPath ?? "Sem entidade")</span></div><pre class="bg-light rounded p-5 fs-8 text-gray-700 text-wrap" style="max-height:520px;overflow:auto;">@Model.TicketPayloadJson</pre></div></div></div>
<div class="col-xl-7"><div class="card card-flush"><div class="card-header"><h3 class="card-title">User Story em Markdown</h3><div class="card-toolbar"><button id="saveDraft" class="btn btn-primary">Salvar rascunho</button></div></div><div class="card-body"><textarea id="draft" class="form-control form-control-solid font-monospace" rows="20" placeholder="# User Story&#10;&#10;## Contexto&#10;## Critérios de aceite">@Model.RequirementMarkdown</textarea><div class="form-text">Use Markdown. Imagens coladas serão incluídas como referência na próxima etapa de anexos.</div></div></div></div></div></div></div>
@section Scripts { <script>document.getElementById('saveDraft').onclick=async()=>{const r=await fetch('/ServiceDesk/SaveDraft/@Model.Id',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requirementMarkdown:document.getElementById('draft').value})});Swal.fire({icon:r.ok?'success':'error',text:r.ok?'Rascunho salvo com sucesso.':'Não foi possível salvar o rascunho.'});};</script> }
