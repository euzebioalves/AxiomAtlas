@using System.Globalization
@using System.Net
@using System.Text.Json
@using System.Text.RegularExpressions
@model Axiom.Atlas.Application.DTOs.ServiceDesk.GlpiTicketWorkspaceDto
@{
    ViewData["Title"] = $"GLPI #{Model.GlpiTicketId}";
    using var ticket = JsonDocument.Parse(Model.TicketPayloadJson);
    var payload = ticket.RootElement;

    string Text(string name) => payload.TryGetProperty(name, out var value) ? value.ToString() : string.Empty;
    string FormatGlpiDate(string value, bool includeTime = false) => DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out var date)
        ? date.ToString(includeTime ? "dd/MM/yyyy HH:mm" : "dd/MM/yyyy", CultureInfo.GetCultureInfo("pt-BR"))
        : value;

    var rawDescription = Text("content");
    var description = WebUtility.HtmlDecode(rawDescription);

    // Preserve the rich GLPI content while isolating executable markup and source theme styling.
    description = Regex.Replace(description, @"<(script|style|iframe|object|embed)[^>]*>.*?</\1>", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"\son\w+\s*=\s*[^\s>]+", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"javascript\s*:", string.Empty, RegexOptions.IgnoreCase);
    description = Regex.Replace(description, @"(?i)(background(?:-color)?|color|font-family)\s*:\s*[^;""']+;?", string.Empty);

    var attachmentProxyBaseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/ServiceDesk/Attachment/{Model.Id}?documentId=";
    description = Regex.Replace(description, @"(?<attribute>src|href)\s*=\s*(?<quote>[""'])(?<url>/front/document\.send\.php\?[^""']*docid=(?<id>\d+)[^""']*)\k<quote>", match =>
        $"{match.Groups["attribute"].Value}={match.Groups["quote"].Value}{attachmentProxyBaseUrl}{match.Groups["id"].Value}{match.Groups["quote"].Value}", RegexOptions.IgnoreCase);

    var glpiBaseUrl = "https://servicedesk.pontoid.com.br";
    if (payload.TryGetProperty("links", out var ticketLinks) && ticketLinks.ValueKind == JsonValueKind.Array)
    {
        var firstLink = ticketLinks.EnumerateArray().FirstOrDefault(x => x.TryGetProperty("href", out _));
        if (firstLink.ValueKind != JsonValueKind.Undefined && Uri.TryCreate(firstLink.GetProperty("href").GetString(), UriKind.Absolute, out var uri))
            glpiBaseUrl = uri.GetLeftPart(UriPartial.Authority);
    }

    var glpiTicketUrl = $"{glpiBaseUrl.TrimEnd('/')}/front/ticket.form.php?id={Model.GlpiTicketId}";

    var descriptionDocument = $"<!doctype html><html><head><base href='{glpiBaseUrl}/' target='_blank'><style>html,body{{background:#1e1e2d!important;color:#d8dbe8!important}}body{{margin:0;padding:1rem;font-family:Inter,Arial,sans-serif;line-height:1.65;overflow-wrap:anywhere}}body *{{background:transparent!important;color:#d8dbe8!important;border-color:#393945!important}}img{{max-width:100%!important;height:auto!important;border-radius:.45rem;cursor:zoom-in}}table{{max-width:100%!important;border-collapse:collapse}}td,th{{padding:.35rem}}a{{color:#50cdff!important}}hr{{border-color:#393945}}</style></head><body>{description}</body></html>";
    var status = Text("status");
    var statusDescription = status switch
    {
        "1" => "Novo",
        "2" => "Em atendimento",
        "3" => "Em atendimento planejado",
        "4" => "Pendente",
        "5" => "Solucionado",
        "6" => "Fechado",
        _ => string.IsNullOrWhiteSpace(status) ? "Não informado" : status
    };
    var createdAt = FormatGlpiDate(Text("date"));
    var updatedAt = FormatGlpiDate(Text("date_mod"));
    using var followUps = JsonDocument.Parse(Model.FollowUpsJson);
    using var attachments = JsonDocument.Parse(Model.AttachmentsJson);
    var followUpCount = followUps.RootElement.ValueKind == JsonValueKind.Array ? followUps.RootElement.GetArrayLength() : 0;
    var hasLinkedUserStory = Model.OpenProjectWorkPackageId.HasValue;
    var hasGlpiLink = !string.IsNullOrWhiteSpace(Model.GlpiDevOpsUrl);
}

<div class="app-content flex-column-fluid">
    <div class="app-container container-xxl">
        <div class="d-flex flex-wrap flex-stack mb-7">
            <div>
                <div class="text-muted fs-7">
                    <a href="@glpiTicketUrl" target="_blank" rel="noopener noreferrer" class="text-muted text-hover-primary" title="Abrir chamado original no GLPI">
                        GLPI #@Model.GlpiTicketId <i class="ki-duotone ki-exit-up fs-7 ms-1"><span class="path1"></span><span class="path2"></span></i>
                    </a>
                    · @(Model.ClientEntityName ?? "Entidade não identificada")
                </div>
                <h1 class="fs-2 fw-bold">@Model.Subject</h1>
            </div>
            <a href="@(ViewData["ReturnUrl"] as string ?? Url.Action("Index"))" class="btn btn-light-primary">
                <i class="ki-duotone ki-arrow-left fs-2"></i>Voltar
            </a>
        </div>

        <div class="row g-7">
            <div class="col-xl-5">
                <div class="card card-flush h-100 service-desk-card">
                    <div class="card-header">
                        <div class="card-toolbar ticket-card-toolbar d-flex gap-2">
                            <span class="badge badge-light-primary">@(Model.ClientEntityName ?? "Entidade não identificada")</span>
                            <span class="badge badge-light-info">Status: @statusDescription</span>
                        </div>
                    </div>
                    <div class="card-body workspace-panel-body">
                        <div class="glpi-ticket-content mb-5">
                            <div class="ticket-content-header">
                                <div class="fw-bold">Descrição do chamado</div>
                                <div class="ticket-metadata">
                                    <span>Criado em <strong>@createdAt</strong></span>
                                    <span>Atualizado em <strong>@updatedAt</strong></span>
                                </div>
                            </div>
                            @if (string.IsNullOrWhiteSpace(description))
                            {
                                <div class="text-muted p-5">O GLPI não retornou uma descrição para este chamado.</div>
                            }
                            else
                            {
                                <div id="glpiTicketScroll" class="ticket-content-scroll scroll-y" data-kt-scroll="true" data-kt-scroll-activate="true" data-kt-scroll-height="540px" data-kt-scroll-save-state="false">
                                    <iframe class="glpi-ticket-frame" sandbox="allow-same-origin" srcdoc="@descriptionDocument" title="Conteúdo do chamado GLPI"></iframe>
                                </div>
                            }
                        </div>

                        <div class="fw-bold mb-3">Acompanhamentos</div>
                        @if (followUpCount == 0)
                        {
                            <div class="text-muted mb-5">Nenhum acompanhamento registrado.</div>
                        }
                        else
                        {
                            <div class="followup-list mb-5">
                                @foreach (var followUp in followUps.RootElement.EnumerateArray())
                                {
                                    var author = followUp.TryGetProperty("authorName", out var authorValue) ? authorValue.ToString() : $"Usuário GLPI #{followUp.GetProperty("users_id")}";
                                    var date = followUp.TryGetProperty("date", out var dateValue) ? FormatGlpiDate(dateValue.ToString(), includeTime: true) : "";
                                    var content = followUp.TryGetProperty("content", out var contentValue) ? Regex.Replace(WebUtility.HtmlDecode(contentValue.ToString()), "<[^>]+>", " ") : "";
                                    <div class="followup-bubble">
                                        <div class="fw-bold fs-8">@author <span class="text-muted fw-normal">· @date</span></div>
                                        <div>@content</div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="fw-bold mb-3">Anexos</div>
                        <div class="attachment-list">
                            @foreach (var attachment in attachments.RootElement.EnumerateArray())
                            {
                                var name = attachment.TryGetProperty("documentName", out var nameValue) ? nameValue.ToString() : $"Documento #{attachment.GetProperty("documents_id")}";
                                var documentId = attachment.GetProperty("documents_id").GetInt32();
                                var url = $"/ServiceDesk/Attachment/{Model.Id}?documentId={documentId}";
                                var isImage = name.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);
                                if (isImage)
                                {
                                    <button type="button" class="attachment-thumb" data-image-url="@url" aria-label="Abrir imagem anexa">
                                        <img src="@url" alt="Imagem anexa" />
                                    </button>
                                }
                                else
                                {
                                    <a class="attachment-item" href="@url" target="_blank" rel="noopener" title="@name" aria-label="Abrir anexo"><i class="ki-duotone ki-file fs-3"></i></a>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-7">
                <div class="card card-flush h-100 service-desk-card">
                    <div class="card-header">
                        <h3 class="card-title">User Story em Markdown</h3>
                        <div class="card-toolbar d-flex gap-3">
                            <button id="saveDraft" class="btn btn-light-primary">Salvar rascunho</button>
                            @if (!hasLinkedUserStory || !hasGlpiLink)
                            {
                                <button id="createUserStory" class="btn btn-primary">@(hasLinkedUserStory ? "Vincular ao GLPI" : "Criar e vincular")</button>
                            }
                        </div>
                    </div>
                    <div class="card-body workspace-panel-body">
                        @if (hasLinkedUserStory)
                        {
                            <div class="alert @(hasGlpiLink ? "alert-success" : "alert-warning") d-flex align-items-center mb-6">
                                <i class="ki-duotone @(hasGlpiLink ? "ki-check-circle" : "ki-information-5") fs-2x me-4"></i>
                                <div class="flex-grow-1">
                                    <div class="fw-bold">User Story #@Model.OpenProjectWorkPackageId criada no OpenProject</div>
                                    <div class="fs-7">@(hasGlpiLink ? "O vínculo ChamadoDevops também foi atualizado no GLPI." : "O vínculo no GLPI está pendente. Revise a configuração e tente vincular novamente.")</div>
                                </div>
                                <div class="d-flex gap-2">
                                    @if (!string.IsNullOrWhiteSpace(Model.OpenProjectWorkPackageUrl))
                                    {
                                        <a href="@Model.OpenProjectWorkPackageUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-light-primary">Abrir User Story</a>
                                    }
                                    <a href="/TimeEntries?workPackageId=@Model.OpenProjectWorkPackageId" class="btn btn-sm btn-primary">Lançar horas</a>
                                </div>
                            </div>
                        }
                        @if (!hasLinkedUserStory)
                        {
                            <div class="mb-6">
                                <label for="openProjectProject" class="form-label required">Projeto no OpenProject</label>
                                <select id="openProjectProject" class="form-select form-select-solid" data-control="select2" data-placeholder="Selecione o projeto para esta User Story">
                                    <option></option>
                                </select>
                                <div class="form-text">A User Story será criada com o tipo <strong>User Story</strong> no projeto selecionado.</div>
                            </div>
                        }
                        <textarea id="draft" class="form-control form-control-solid font-monospace" rows="20" placeholder="# User Story&#10;&#10;## Contexto&#10;## Critérios de aceite">@Model.RequirementMarkdown</textarea>
                        <div class="form-text">Use Markdown. Imagens coladas serão incluídas como referência na próxima etapa de anexos.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="attachmentPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0 justify-content-end"><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button></div>
            <div class="modal-body text-center pt-0"><img id="attachmentPreviewImage" class="mw-100 mh-600px" alt="Imagem anexa" /></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modalElement = document.getElementById('attachmentPreviewModal');
        const previewImage = document.getElementById('attachmentPreviewImage');
        const openAttachmentPreview = (url) => {
            previewImage.src = url;
            bootstrap.Modal.getOrCreateInstance(modalElement).show();
        };

        const applyTicketTheme = (frame) => {
            const document = frame.contentDocument;
            if (!document) return;

            const isDark = frame.ownerDocument.documentElement.getAttribute('data-bs-theme') === 'dark';
            const palette = isDark
                ? { background: '#1e1e2d', text: '#d8dbe8', border: '#393945', link: '#50cdff' }
                : { background: '#f8f9fc', text: '#3f4254', border: '#e1e3ea', link: '#009ef7' };
            let style = document.getElementById('axiom-ticket-theme');
            if (!style) {
                style = document.createElement('style');
                style.id = 'axiom-ticket-theme';
                document.head.appendChild(style);
            }

            style.textContent = `html,body{background:${palette.background}!important;color:${palette.text}!important}body *{background:transparent!important;color:${palette.text}!important;border-color:${palette.border}!important}a{color:${palette.link}!important}`;
            frame.style.background = palette.background;
        };

        document.getElementById('saveDraft').onclick = async () => {
            const response = await fetch('/ServiceDesk/SaveDraft/@Model.Id', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ requirementMarkdown: document.getElementById('draft').value })
            });
            Swal.fire({ icon: response.ok ? 'success' : 'error', text: response.ok ? 'Rascunho salvo com sucesso.' : 'Não foi possível salvar o rascunho.' });
        };

        const projectSelect = document.getElementById('openProjectProject');
        const createUserStoryButton = document.getElementById('createUserStory');
        const hasExistingUserStory = @hasLinkedUserStory.ToString().ToLowerInvariant();

        const loadOpenProjectProjects = async () => {
            if (!projectSelect) return;

            createUserStoryButton?.setAttribute('disabled', 'disabled');
            try {
                const response = await fetch('/ServiceDesk/OpenProjectProjects');
                const projects = await response.json();
                if (!response.ok) throw new Error(projects.message || 'Não foi possível carregar os projetos do OpenProject.');

                projects.forEach(project => {
                    const label = project.identifier ? `${project.name} (${project.identifier})` : project.name;
                    projectSelect.add(new Option(label, project.id));
                });

                if (window.jQuery && !window.jQuery(projectSelect).hasClass('select2-hidden-accessible')) {
                    window.jQuery(projectSelect).select2({
                        placeholder: 'Selecione o projeto para esta User Story',
                        width: '100%'
                    });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', text: error.message || 'Não foi possível carregar os projetos do OpenProject.' });
            } finally {
                createUserStoryButton?.removeAttribute('disabled');
            }
        };

        createUserStoryButton?.addEventListener('click', async () => {
            const projectId = Number(projectSelect?.value);
            const requirementMarkdown = document.getElementById('draft').value;
            if (!hasExistingUserStory && !projectId) {
                Swal.fire({ icon: 'warning', text: 'Selecione o projeto de destino no OpenProject.' });
                return;
            }

            if (!requirementMarkdown.trim()) {
                Swal.fire({ icon: 'warning', text: 'Documente a User Story antes de criá-la.' });
                return;
            }

            createUserStoryButton.setAttribute('disabled', 'disabled');
            createUserStoryButton.setAttribute('data-kt-indicator', 'on');
            try {
                const response = await fetch('/ServiceDesk/CreateUserStory/@Model.Id', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId: hasExistingUserStory ? 0 : projectId, requirementMarkdown })
                });
                const payload = await response.json();
                if (!response.ok) throw new Error(payload.message || 'Não foi possível criar a User Story.');

                await Swal.fire({
                    icon: 'success',
                    text: 'User Story criada no OpenProject e vinculada automaticamente ao chamado no GLPI.'
                });
                window.location.reload();
            } catch (error) {
                const message = error.message || 'Não foi possível concluir a criação da User Story.';
                await Swal.fire({ icon: 'error', text: message });

                // A Work Package pode ter sido persistida antes de uma falha no GLPI.
                // Recarregar permite visualizar o estado salvo e repetir somente o vínculo pendente.
                if (message.includes('User Story foi criada')) window.location.reload();
            } finally {
                createUserStoryButton.removeAttribute('disabled');
                createUserStoryButton.removeAttribute('data-kt-indicator');
            }
        });

        loadOpenProjectProjects();

        document.querySelectorAll('.glpi-ticket-frame').forEach(frame => frame.addEventListener('load', () => {
            const body = frame.contentDocument?.body;
            if (!body) return;

            applyTicketTheme(frame);
            frame.style.height = `${Math.max(body.scrollHeight + 8, 360)}px`;
            body.addEventListener('click', event => {
                const image = event.target.closest('img');
                if (!image || !image.currentSrc.includes('/ServiceDesk/Attachment/')) return;
                event.preventDefault();
                event.stopPropagation();
                openAttachmentPreview(image.currentSrc);
            });
            KTScroll.getInstance(document.getElementById('glpiTicketScroll'))?.update();
        }));

        KTScroll.createInstances('#glpiTicketScroll');
        document.querySelectorAll('.attachment-thumb').forEach(item => item.addEventListener('click', () => openAttachmentPreview(item.dataset.imageUrl)));
        new MutationObserver(() => document.querySelectorAll('.glpi-ticket-frame').forEach(applyTicketTheme)).observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
    </script>
}

<style>
    .service-desk-card { display: flex; flex-direction: column; min-height: calc(100vh - 260px); }
    .service-desk-card .card-header { flex: 0 0 76px; height: 76px; min-height: 76px; padding: 16px 28px; }
    .workspace-panel-body { flex: 1 1 auto; padding: 18px 28px 28px; }
    .ticket-card-toolbar { margin-left: 0 !important; }
    .ticket-metadata { display: flex; gap: 20px; color: var(--bs-body-color); font-size: .8rem; }
    .ticket-metadata strong { color: var(--bs-heading-color); margin-left: 4px; }
    .glpi-ticket-content { background: var(--bs-gray-100); border-radius: .475rem; }
    .ticket-content-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 18px 18px 12px; }
    .ticket-content-scroll { height: 540px; padding: 0 18px 18px; }
    .glpi-ticket-frame { display: block; width: 100%; min-height: 360px; border: 0; background: var(--bs-gray-100); border-radius: .475rem; }
    .followup-list { display: flex; flex-direction: column; gap: 10px; }
    .followup-bubble { align-self: flex-start; max-width: 88%; background: var(--bs-gray-200); border-radius: 12px 12px 12px 2px; padding: 10px 12px; color: var(--bs-gray-800); font-size: .85rem; }
    .followup-bubble:nth-child(even) { align-self: flex-end; background: var(--bs-primary); color: #fff; border-radius: 12px 12px 2px 12px; }
    .attachment-list { display: flex; flex-wrap: wrap; gap: 8px; }
    .attachment-item { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; background: var(--bs-gray-200); border-radius: 6px; color: var(--bs-primary); }
    .attachment-thumb { width: 124px; border: 1px solid var(--bs-gray-700); border-radius: 6px; padding: 5px; background: var(--bs-gray-100); overflow: hidden; }
    .attachment-thumb img { display: block; width: 112px; height: 76px; object-fit: cover; border-radius: 4px; }
    @@media (max-width: 1199.98px) { .service-desk-card .card-header { flex-basis: auto; height: auto; min-height: 72px; } }
    @@media (max-width: 991.98px) { .ticket-content-header { align-items: flex-start; flex-direction: column; } .ticket-metadata { flex-wrap: wrap; } }
</style>
