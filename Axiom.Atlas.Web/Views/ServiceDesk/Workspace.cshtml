@using System.Net
@using System.Text.Json
@using System.Text.RegularExpressions
@model Axiom.Atlas.Application.DTOs.ServiceDesk.GlpiTicketWorkspaceDto
@{
    ViewData["Title"] = $"GLPI #{Model.GlpiTicketId}";
    using var ticket = JsonDocument.Parse(Model.TicketPayloadJson);
    var payload = ticket.RootElement;
    string Text(string name) => payload.TryGetProperty(name, out var value) ? value.ToString() : string.Empty;
    var rawDescription = Text("content");
    var description = WebUtility.HtmlDecode(rawDescription);
    // O GLPI pode armazenar HTML no conteúdo; removemos apenas vetores executáveis antes da renderização.
    description = Regex.Replace(description, @"<(script|style|iframe|object|embed)[^>]*>.*?</\1>", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"\son\w+\s*=\s*[^\s>]+", string.Empty, RegexOptions.IgnoreCase | RegexOptions.Singleline);
    description = Regex.Replace(description, @"javascript\s*:", string.Empty, RegexOptions.IgnoreCase);
    var glpiBaseUrl = "https://servicedesk.pontoid.com.br";
    if (payload.TryGetProperty("links", out var ticketLinks) && ticketLinks.ValueKind == JsonValueKind.Array)
    {
        var firstLink = ticketLinks.EnumerateArray().FirstOrDefault(x => x.TryGetProperty("href", out _));
        if (firstLink.ValueKind != JsonValueKind.Undefined && Uri.TryCreate(firstLink.GetProperty("href").GetString(), UriKind.Absolute, out var uri)) glpiBaseUrl = uri.GetLeftPart(UriPartial.Authority);
    }
    var descriptionDocument = $"<!doctype html><html><head><base href='{glpiBaseUrl}/' target='_blank'><style>html,body{{background:#1e1e2d!important;color:#d8dbe8!important}}body{{margin:0;padding:1rem;font-family:Inter,Arial,sans-serif;line-height:1.65;overflow-wrap:anywhere}}img{{max-width:100%!important;height:auto!important;border-radius:.45rem}}table{{max-width:100%!important;border-collapse:collapse}}td,th{{padding:.35rem}}a{{color:#50cdff!important}}hr{{border-color:#393945}}</style></head><body>{description}</body></html>";
    var status = Text("status");
    var createdAt = Text("date");
    var updatedAt = Text("date_mod");
    using var followUps = JsonDocument.Parse(Model.FollowUpsJson);
    using var attachments = JsonDocument.Parse(Model.AttachmentsJson);
    var followUpCount = followUps.RootElement.ValueKind == JsonValueKind.Array ? followUps.RootElement.GetArrayLength() : 0;
    var attachmentCount = attachments.RootElement.ValueKind == JsonValueKind.Array ? attachments.RootElement.GetArrayLength() : 0;
}
<div class="app-content flex-column-fluid"><div class="app-container container-xxl"><div class="d-flex flex-wrap flex-stack mb-7"><div><div class="text-muted fs-7">GLPI #@Model.GlpiTicketId · @(Model.ClientEntityName ?? "Entidade não identificada")</div><h1 class="fs-2 fw-bold">@Model.Subject</h1></div><a asp-action="Index" class="btn btn-light-primary">Nova importação</a></div>
<div class="row g-7"><div class="col-xl-5"><div class="card card-flush h-100 service-desk-card"><div class="card-header"><h3 class="card-title">Dossiê do chamado</h3><div class="card-toolbar d-flex flex-wrap gap-2"><span class="badge badge-light-primary">@(Model.EntityPath ?? "Sem entidade")</span><span class="badge badge-light-info">Status GLPI: @status</span></div></div><div class="card-body"><div class="ticket-metadata mb-4"><span>Criado em <strong>@createdAt</strong></span><span>Atualizado em <strong>@updatedAt</strong></span></div><div class="border border-dashed rounded p-5 mb-5 glpi-ticket-content"><div class="fw-bold mb-4">Descrição do chamado</div>@if (string.IsNullOrWhiteSpace(description)) { <div class="text-muted">O GLPI não retornou uma descrição para este chamado.</div> } else { <iframe class="glpi-ticket-frame" sandbox="allow-same-origin" srcdoc="@descriptionDocument" title="Conteúdo do chamado GLPI"></iframe> }</div><div class="fw-bold mb-3">Acompanhamentos</div>@if (followUpCount == 0) { <div class="text-muted mb-5">Nenhum acompanhamento registrado.</div> } else { <div class="followup-list mb-5">@foreach (var followUp in followUps.RootElement.EnumerateArray()) { var author = followUp.TryGetProperty("authorName", out var authorValue) ? authorValue.ToString() : $"Usuário GLPI #{followUp.GetProperty("users_id")}"; var date = followUp.TryGetProperty("date", out var dateValue) ? dateValue.ToString() : ""; var content = followUp.TryGetProperty("content", out var contentValue) ? Regex.Replace(WebUtility.HtmlDecode(contentValue.ToString()), "<[^>]+>", " ") : ""; <div class="followup-bubble"><div class="fw-bold fs-8">@author <span class="text-muted fw-normal">· @date</span></div><div>@content</div></div> }</div> }<div class="fw-bold mb-3">Anexos</div><div class="attachment-list">@foreach (var attachment in attachments.RootElement.EnumerateArray()) { var name = attachment.TryGetProperty("documentName", out var nameValue) ? nameValue.ToString() : $"Documento #{attachment.GetProperty("documents_id")}"; var url = attachment.TryGetProperty("documentUrl", out var urlValue) ? urlValue.ToString() : $"{glpiBaseUrl}/front/document.send.php?docid={attachment.GetProperty("documents_id")}"; var isImage = name.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".webp", StringComparison.OrdinalIgnoreCase); if (isImage) { <button type="button" class="attachment-thumb" data-image-url="@url" data-image-name="@name"><img src="@url" alt="@name" /><span>@name</span></button> } else { <a class="attachment-item" href="@url" target="_blank" rel="noopener"><i class="ki-duotone ki-file fs-3"></i>@name</a> } }</div></div></div></div>
<div class="col-xl-7"><div class="card card-flush service-desk-card"><div class="card-header"><h3 class="card-title">User Story em Markdown</h3><div class="card-toolbar"><button id="saveDraft" class="btn btn-primary">Salvar rascunho</button></div></div><div class="card-body"><textarea id="draft" class="form-control form-control-solid font-monospace" rows="20" placeholder="# User Story&#10;&#10;## Contexto&#10;## Critérios de aceite">@Model.RequirementMarkdown</textarea><div class="form-text">Use Markdown. Imagens coladas serão incluídas como referência na próxima etapa de anexos.</div></div></div></div></div></div></div>
<div class="modal fade" id="attachmentPreviewModal" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-centered"><div class="modal-content bg-dark"><div class="modal-header border-0"><h3 class="modal-title text-white" id="attachmentPreviewTitle">Imagem anexa</h3><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body text-center"><img id="attachmentPreviewImage" class="mw-100 mh-600px" alt="Imagem anexa" /></div></div></div></div>
@section Scripts { <script>document.getElementById('saveDraft').onclick=async()=>{const r=await fetch('/ServiceDesk/SaveDraft/@Model.Id',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({requirementMarkdown:document.getElementById('draft').value})});Swal.fire({icon:r.ok?'success':'error',text:r.ok?'Rascunho salvo com sucesso.':'Não foi possível salvar o rascunho.'});};document.querySelectorAll('.glpi-ticket-frame').forEach(frame=>frame.addEventListener('load',()=>{const body=frame.contentDocument?.body;if(body)frame.style.height=`${Math.min(Math.max(body.scrollHeight+8,360),760)}px`;}));const modalElement=document.getElementById('attachmentPreviewModal'),previewImage=document.getElementById('attachmentPreviewImage'),previewTitle=document.getElementById('attachmentPreviewTitle');document.querySelectorAll('.attachment-thumb').forEach(item=>item.addEventListener('click',()=>{previewImage.src=item.dataset.imageUrl;previewTitle.textContent=item.dataset.imageName;bootstrap.Modal.getOrCreateInstance(modalElement).show();}));</script> }
<style>.service-desk-card{min-height:calc(100vh - 260px)}.service-desk-card .card-header{min-height:72px;padding:16px 28px}.service-desk-card .card-body{padding:18px 28px 28px}.ticket-metadata{display:flex;gap:20px;color:var(--bs-gray-600);font-size:.8rem}.ticket-metadata strong{color:var(--bs-gray-300);margin-left:4px}.glpi-ticket-content{background:#1b1b27}.glpi-ticket-frame{display:block;width:100%;min-height:360px;border:1px solid var(--bs-gray-700);background:#1e1e2d;border-radius:.475rem}.followup-list{display:flex;flex-direction:column;gap:10px}.followup-bubble{align-self:flex-start;max-width:88%;background:var(--bs-gray-200);border-radius:12px 12px 12px 2px;padding:10px 12px;color:var(--bs-gray-800);font-size:.85rem}.followup-bubble:nth-child(even){align-self:flex-end;background:var(--bs-primary);color:#fff;border-radius:12px 12px 2px 12px}.attachment-list{display:flex;flex-wrap:wrap;gap:8px}.attachment-item{display:inline-flex;align-items:center;gap:6px;padding:8px 10px;background:var(--bs-gray-200);border-radius:6px;color:var(--bs-primary);font-size:.85rem}.attachment-thumb{width:124px;border:1px solid var(--bs-gray-700);border-radius:6px;padding:5px;background:var(--bs-gray-100);color:var(--bs-gray-700);font-size:.72rem;text-align:left;overflow:hidden}.attachment-thumb img{display:block;width:112px;height:76px;object-fit:cover;border-radius:4px;margin-bottom:4px}</style>
