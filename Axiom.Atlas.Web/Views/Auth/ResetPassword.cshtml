@model Axiom.Atlas.Web.Model.Login.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <title>Redefinir Senha - Axiom Atlas</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" />
    <link href="~/metronic8/css/plugins.bundle.css" rel="stylesheet" type="text/css" />
    <link href="~/metronic8/css/style.bundle.css" rel="stylesheet" type="text/css" />
</head>
<body id="kt_body" class="app-blank bgi-size-cover bgi-attachment-fixed bgi-position-center">
    
    <div class="d-flex flex-column flex-root" id="kt_app_root">
        <style>
            body { background-image: url('~/metronic8/images/bg10.jpeg'); }
            [data-bs-theme="dark"] body { background-image: url('~/metronic8/images/bg10-dark.jpeg'); }
        </style>
        
        <div class="d-flex flex-column flex-lg-row flex-column-fluid">
            <div class="d-flex flex-lg-row-fluid">
                <div class="d-flex flex-column flex-center pb-0 pb-lg-10 p-10 w-100">
                    <img class="theme-light-show mx-auto mw-100 w-150px w-lg-300px mb-10 mb-lg-20" src="~/metronic8/images/agency.png" alt="" />
                    <img class="theme-dark-show mx-auto mw-100 w-150px w-lg-300px mb-10 mb-lg-20" src="~/metronic8/images/agency-dark.png" alt="" />
                    <h1 class="text-gray-800 fs-2qx fw-bold text-center mb-7">Proteja seu acesso ao Axiom Atlas</h1>
                    <div class="text-gray-600 fs-base text-center fw-semibold">
                        Defina uma senha forte para continuar usando os recursos oficiais do sistema.
                    </div>
                </div>
            </div>
            
            <div class="d-flex flex-column-fluid flex-lg-row-auto justify-content-center justify-content-lg-end p-12">
                <div class="bg-body d-flex flex-column flex-center rounded-4 w-md-600px p-10">
                    <div class="d-flex flex-center flex-column align-items-stretch h-lg-100 w-md-400px">
                        <div class="d-flex flex-center flex-column flex-column-fluid pb-15 pb-lg-20">
                            
                            <form class="form w-100" id="axiom_reset_password_form" method="post" asp-action="ResetPassword" asp-controller="Auth">
                                
                                <input type="hidden" asp-for="Email" />
                                <input type="hidden" asp-for="Token" />

                                <div class="text-center mb-11">
                                    <div class="d-block d-lg-flex p-14 mb-8">
                                        <img alt="Logo" src="~/metronic8/fonts/default-dark.svg" class="logo-default">
                                    </div>
                                    <h1 class="text-gray-900 fw-bolder mb-3">Nova Senha</h1>
                                    <div class="text-gray-500 fw-semibold fs-6">
                                        Digite sua nova senha de acesso.
                                    </div>
                                </div>

                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div class="alert alert-danger mb-8">
                                        @Html.ValidationSummary(true, "")
                                    </div>
                                }

                                <div class="fv-row mb-8">
                                    <input asp-for="NewPassword" type="password" placeholder="Nova Senha" autocomplete="off" class="form-control form-control-solid" required>
                                    <span asp-validation-for="NewPassword" class="text-danger mt-2 d-block"></span>
                                </div>

                                <div class="fv-row mb-8">
                                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirme a Nova Senha" autocomplete="off" class="form-control form-control-solid" required>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger mt-2 d-block"></span>
                                </div>

                                <div class="d-flex flex-wrap justify-content-center pb-lg-0">
                                    <button type="submit" id="btn_submit_reset" class="btn btn-primary me-4">
                                        <span class="indicator-label">Salvar Senha</span>
                                        <span class="indicator-progress">
                                            Aguarde... <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                        </span>
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/metronic8/js/plugins.bundle.js"></script>
    <script src="~/metronic8/js/scripts.bundle.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
    $('#axiom_reset_password_form').on('submit', function (e) {
        // $(this).valid() é a mágica: ele checa se o jQuery Validation aprovou todos os campos
        if ($(this).valid()) {
            var btn = document.getElementById('btn_submit_reset');
            btn.querySelector('.indicator-label').style.display = 'none';
            btn.querySelector('.indicator-progress').style.display = 'inline-block';
            btn.setAttribute('data-kt-indicator', 'on');
            
            // Aqui podemos até desabilitar o botão com segurança para evitar duplo clique, 
            // pois já sabemos que o formulário VAI para o servidor.
            // setTimeout(() => btn.disabled = true, 10);
        }
    });
</script>
</body>
</html>
