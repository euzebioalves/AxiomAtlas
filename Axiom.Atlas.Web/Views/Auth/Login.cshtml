@model Axiom.Atlas.Web.Model.Login.LoginViewModel
@{
    Layout = null; // Isso anula qualquer herança do _Layout.cshtml ou _ViewStart.cshtml
}

<!DOCTYPE html>
<html lang="pt-br">
<!--begin::Head-->
<head>
    <title>Login - Axiom Atlas</title>
    <meta http-equiv="content-type" content="text/html;charset=UTF-8" />
    <meta name="description" content="Axiom Atlas - Plataforma interna de gestão de apontamentos, ponto eletrônico, auditoria e integrações." />
    <meta name="keywords" content="Axiom Atlas, apontamentos, ponto eletrônico, auditoria, OpenProject" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Axiom Atlas" />
    <meta property="og:site_name" content="Axiom Atlas" />
    <link rel="shortcut icon" href="~/favicon.ico" />

    <!--begin::Fonts(mandatory for all pages)-->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Inter:300,400,500,600,700" />
    <!--end::Fonts-->
    <!--begin::Global Stylesheets Bundle(mandatory for all pages)-->
    <link href="~/metronic8/css/plugins.bundle.css" rel="stylesheet" type="text/css" />
    <link href="~/metronic8/css/style.bundle.css" rel="stylesheet" type="text/css" />
    <!--end::Global Stylesheets Bundle-->

    <script>
            // Frame-busting to prevent site from being loaded within a frame without permission (click-jacking)
            if (window.top != window.self) {
                window.top.location.replace(window.self.location.href);
            }
    </script>
</head>
<!--end::Head-->
<!--begin::Body-->
<body id="kt_body" class="app-blank bgi-size-cover bgi-attachment-fixed bgi-position-center">
    <!--begin::Theme mode setup on page load-->
    <script>
            var defaultThemeMode = "light";
            var themeMode;

            if ( document.documentElement ) {
                if ( document.documentElement.hasAttribute("data-bs-theme-mode")) {
                    themeMode = document.documentElement.getAttribute("data-bs-theme-mode");
                } else {
                    if ( localStorage.getItem("data-bs-theme") !== null ) {
                        themeMode = localStorage.getItem("data-bs-theme");
                    } else {
                        themeMode = defaultThemeMode;
                    }
                }

                if (themeMode === "system") {
                    themeMode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
                }

                document.documentElement.setAttribute("data-bs-theme", themeMode);
            }
    </script>
    <!--end::Theme mode setup on page load-->
    <!--begin::Root-->
    <div class="d-flex flex-column flex-root" id="kt_app_root">
        <!--begin::Page bg image-->
        <style>
                    body {
                        background-image: url('~/metronic8/images/bg10.jpeg');
                    }

                    [data-bs-theme="dark"] body {
                        background-image: url('~/metronic8/images/bg10-dark.jpeg');
                    }
        </style>
        <!--end::Page bg image-->
        <!--begin::Authentication - Sign-in -->
        <div class="d-flex flex-column flex-lg-row flex-column-fluid">
            <!--begin::Aside-->
            <div class="d-flex flex-lg-row-fluid">
                <!--begin::Content-->
                <div class="d-flex flex-column flex-center pb-0 pb-lg-10 p-10 w-100">
                    <!--begin::Image-->
                    <img class="theme-light-show mx-auto mw-100 w-150px w-lg-300px mb-10 mb-lg-20" src="~/metronic8/images/agency.png" alt="" />
                    <img class="theme-dark-show mx-auto mw-100 w-150px w-lg-300px mb-10 mb-lg-20" src="~/metronic8/images/agency-dark.png" alt="" />
                    <!--end::Image-->
                    <!--begin::Title-->
                    <h1 class="text-gray-800 fs-2qx fw-bold text-center mb-7">
                        Gestão consistente, decisões mais seguras
                    </h1>
                    <!--end::Title-->
                    <!--begin::Text-->
                    <div class="text-gray-600 fs-base text-center fw-semibold">
                        Centralize apontamentos, ponto eletrônico, auditoria e integrações em uma experiência única.
                    </div>
                    <!--end::Text-->
                </div>
                <!--end::Content-->
            </div>
            <!--begin::Aside-->
            <!--begin::Body-->
            <div class="d-flex flex-column-fluid flex-lg-row-auto justify-content-center justify-content-lg-end p-12">
                <!--begin::Wrapper-->
                <div class="bg-body d-flex flex-column flex-center rounded-4 w-md-600px p-10">
                    <!--begin::Content-->
                    <div class="d-flex flex-center flex-column align-items-stretch h-lg-100 w-md-400px">
                        <!--begin::Wrapper-->
                        <div class="d-flex flex-center flex-column flex-column-fluid pb-15 pb-lg-20">
                    
                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success bg-success text-white mb-8 text-center fw-semibold">
                                    @TempData["SuccessMessage"]
                                </div>
                            }

                            <!--begin::Form-->
                            <form class="form w-100" novalidate="novalidate" id="axiom_login_form" method="post" asp-action="Login" asp-controller="Auth">
                                <!--begin::Heading-->
                                <div class="text-center mb-11">
                                    <!--begin::Logo-->
                                    <div class="d-block d-lg-flex p-14 mb-8">
                                        <img alt="Logo" src="~/metronic8/fonts/default-dark.svg" class="logo-default">
                                    </div>
                                    <!--end::Logo-->
                                    <!--begin::Title-->
                                    <h1 class="text-gray-900 fw-bolder mb-3">
                                        Axiom Atlas
                                    </h1>
                                    <!--end::Title-->
                                    <!--begin::Subtitle-->
                                    <div class="text-gray-500 fw-semibold fs-6">
                                        A verdade não pode ser contestada quando os dados são consistentes!
                                    </div>
                                    <!--end::Subtitle--->
                                </div>
                                <!--begin::Erros and Alerts-->
                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div class="alert alert-danger mb-8">
                                        @Html.ValidationSummary(true, "")
                                    </div>
                                }
                                <!--end::Erros and Alerts-->
                                <!--begin::Input group--->
                                <div class="fv-row mb-8">
                                    <!--begin::Email-->
                                    <!--<input type="text" placeholder="Email" name="email" autocomplete="off" class="form-control bg-transparent" />-->
                                    <input asp-for="Username" type="email" placeholder="Usuário ou Email" autocomplete="off" class="form-control form-control-solid">
                                    <!--end::Email-->
                                </div>

                                <!--end::Input group--->
                                <div class="fv-row mb-3">
                                    <!--begin::Password-->
                                    <!--<input type="password" placeholder="Password" name="password" autocomplete="off" class="form-control bg-transparent" />-->
                                    <input asp-for="Password" type="password" placeholder="Senha" autocomplete="off" class="form-control form-control-solid">
                                    <!--end::Password-->
                                </div>
                                <!--end::Input group--->
                                <!--begin::Wrapper-->
                                <div class="d-flex flex-stack flex-wrap gap-3 fs-base fw-semibold mb-8">
                                    <div></div>

                                    <!--begin::Link-->
                                    <a asp-controller="Auth" asp-action="ForgotPassword" class="link-primary">
                                        Esqueci minha senha!
                                    </a>
                                    <!--end::Link-->
                                </div>
                                <!--end::Wrapper-->
                                <!--begin::Submit button-->
                                <div class="d-grid mb-10">
                                    <button type="submit" id="btn_submit_login" class="btn btn-primary">
            
                                        <!--begin::Indicator label-->
                                        <span class="indicator-label">Login</span>
                                        <!--end::Indicator label-->
                                        <!--begin::Indicator progress-->
                                        <span class="indicator-progress">
                                            Please wait...    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                        </span>
                                        <!--end::Indicator progress-->
                                    </button>
                                </div>
                                <!--end::Submit button-->
                            </form>
                            <!--end::Form-->

                        </div>
                        <!--end::Wrapper-->
                        <!--begin::Footer-->
                        <div class="d-flex flex-center">
                            <span class="text-muted fw-semibold fs-7">Axiom Atlas © @DateTime.Now.Year</span>
                        </div>
                        <!--end::Footer-->
                    </div>
                    <!--end::Content-->
                </div>
                <!--end::Wrapper-->
            </div>
            <!--end::Body-->
        </div>
        <!--end::Authentication - Sign-in-->
    </div>
    <!--end::Root-->
    <!--begin::Javascript-->
    <!--begin::Global Javascript Bundle(mandatory for all pages)-->
    <script src="~/metronic8/js/plugins.bundle.js"></script>
    <script src="~/metronic8/js/scripts.bundle.js"></script>
    <!--end::Global Javascript Bundle-->
    <!--begin::Custom Javascript(used for this page only)-->
    <script src="~/metronic8/js/general.js"></script>
    <!--end::Custom Javascript-->
    <!--begin::Send form to login-->
    <script>
            document.getElementById('axiom_login_form').addEventListener('submit', function() {
            var btn = document.getElementById('btn_submit_login');
            btn.querySelector('.indicator-label').style.display = 'none';
            btn.querySelector('.indicator-progress').style.display = 'inline-block';
            btn.setAttribute('data-kt-indicator', 'on');
            btn.disabled = true;
            });
    </script>
    <!--end::Send form to login-->
    <!--end::Javascript-->
</body>
<!--end::Body-->
</html>
