@model Axiom.Atlas.Web.Model.Integrations.GlpiSettingsViewModel
@{ ViewData["Title"] = "Integração: GLPI"; }
<div class="d-flex flex-column flex-column-fluid"><div class="app-toolbar py-3 py-lg-6"><div class="app-container container-xxl"><h1 class="text-gray-900 fw-bold fs-3 mb-1">Integração: GLPI</h1><div class="text-muted fw-semibold fs-7">Service desk, classificação de melhorias e rastreabilidade de User Stories.</div></div></div><div class="app-content flex-column-fluid"><div class="app-container container-xxl"><div class="card card-flush"><div class="card-header"><h3 class="card-title">Conexão com o GLPI</h3></div><form asp-action="SaveGlpi" method="post"><div class="card-body"><div class="notice d-flex bg-light-primary rounded border-primary border border-dashed p-6 mb-8"><i class="ki-duotone ki-information fs-2tx text-primary me-4"></i><div class="fw-semibold text-gray-700">Os tokens são criptografados. Após validar a conexão, informe as chaves técnicas dos campos do plugin “Campos adicionais”.</div></div>@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> } @if (TempData["ErrorMessage"] != null) { <div class="alert alert-danger">@TempData["ErrorMessage"]</div> }<div class="row g-6"><div class="col-12"><label class="required form-label">BASE_URL</label><input asp-for="BaseUrl" class="form-control form-control-solid" placeholder="https://glpi.empresa.com" /></div><div class="col-md-6"><label class="required form-label">APP_TOKEN</label><input asp-for="AppToken" type="password" class="form-control form-control-solid" /></div><div class="col-md-6"><label class="required form-label">USER_TOKEN</label><input asp-for="UserToken" type="password" class="form-control form-control-solid" /></div><div class="col-md-6"><label class="form-label">Chave “Classificação”</label><input asp-for="ClassificationFieldKey" class="form-control form-control-solid" placeholder="plugin_fields_..." /></div><div class="col-md-6"><label class="form-label">Chave “ChamadoDevops”</label><input asp-for="DevOpsUrlFieldKey" class="form-control form-control-solid" placeholder="plugin_fields_..." /></div></div></div><div class="card-footer d-flex justify-content-end gap-3"><button type="button" id="testGlpi" class="btn btn-light-primary">Testar conexão</button><button class="btn btn-primary">Salvar configurações</button></div></form></div></div></div></div>
@section Scripts { <script>document.getElementById('testGlpi').onclick=async()=>{const r=await fetch('/Integrations/TestGlpi',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({baseUrl:BaseUrl.value,appToken:AppToken.value,userToken:UserToken.value,classificationFieldKey:ClassificationFieldKey.value,devOpsUrlFieldKey:DevOpsUrlFieldKey.value})});const d=await r.json();Swal.fire({icon:r.ok?'success':'error',text:`${d.message}${d.glpiVersion?`\nGLPI ${d.glpiVersion}`:''}`});};</script> }
