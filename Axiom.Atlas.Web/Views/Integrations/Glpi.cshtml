@model Axiom.Atlas.Web.Model.Integrations.GlpiSettingsViewModel
@{
    ViewData["Title"] = "Integração: GLPI";
}

<div class="d-flex flex-column flex-column-fluid">
    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Integração GLPI</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-hover-primary">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <i class="ki-duotone ki-right fs-7 text-gray-700 mx-n1"><span class="path1"></span><span class="path2"></span></i>
                    </li>
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Integrations" asp-action="Operations" class="text-muted text-hover-primary">Integrações</a>
                    </li>
                    <li class="breadcrumb-item">
                        <i class="ki-duotone ki-right fs-7 text-gray-700 mx-n1"><span class="path1"></span><span class="path2"></span></i>
                    </li>
                    <li class="breadcrumb-item text-gray-800">GLPI Service Desk</li>
                </ul>
            </div>
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-xxl">
        <div class="card shadow-sm">
            <div class="card-header">
                <div class="card-title flex-column align-items-start">
                    <h3 class="mb-1">Configurações do GLPI</h3>
                    <span class="text-muted fs-7 fw-semibold">Service desk, solicitações de melhoria e rastreabilidade de User Stories.</span>
                </div>
            </div>

            <form asp-action="SaveGlpi" method="post">
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mb-8">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mb-8">@TempData["ErrorMessage"]</div>
                    }

                    <div class="notice d-flex bg-light-primary rounded border-primary border border-dashed p-6 mb-8">
                        <i class="ki-duotone ki-information-5 fs-2tx text-primary me-4"><span class="path1"></span><span class="path2"></span><span class="path3"></span></i>
                        <div class="fw-semibold text-gray-700">
                            Os tokens são protegidos antes de serem armazenados. O Axiom Atlas usa o ambiente ativo para importar chamados e atualizar o vínculo ChamadoDevops.
                        </div>
                    </div>

                    <div class="mb-10 p-5 bg-light rounded d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-4">
                        <div>
                            <h4 class="text-gray-900 fw-bold mb-1">Ambiente ativo</h4>
                            <div class="text-gray-500 fs-6">Escolha qual ambiente GLPI será usado nas consultas da área de demandas.</div>
                        </div>
                        <select asp-for="ActiveEnvironment" class="form-select form-select-solid w-200px" data-control="select2" data-hide-search="true">
                            <option value="Homologation">Homologação</option>
                            <option value="Production">Produção</option>
                        </select>
                    </div>

                    <ul class="nav nav-tabs nav-line-tabs nav-line-tabs-2x mb-5 fs-6">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#glpi_tab_homologation">
                                <i class="ki-duotone ki-flask fs-2 me-2"><span class="path1"></span><span class="path2"></span></i>Homologação
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#glpi_tab_production">
                                <i class="ki-duotone ki-rocket fs-2 me-2"><span class="path1"></span><span class="path2"></span></i>Produção
                            </a>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="glpi_tab_homologation">
                            <partial name="_GlpiEnvironmentFields" model="Model.Homologation" view-data='new ViewDataDictionary(ViewData) { { "EnvironmentLabel", "Homologação" }, { "EnvironmentName", "Homologation" } }' />
                        </div>
                        <div class="tab-pane fade" id="glpi_tab_production">
                            <partial name="_GlpiEnvironmentFields" model="Model.Production" view-data='new ViewDataDictionary(ViewData) { { "EnvironmentLabel", "Produção" }, { "EnvironmentName", "Production" } }' />
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-end py-6 px-9">
                    <button type="submit" class="btn btn-primary">Salvar configurações</button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.js-test-glpi').forEach(button => {
            button.addEventListener('click', async function () {
                const prefix = this.dataset.prefix;
                const field = name => document.getElementById(`${prefix}_${name}`)?.value;
                const originalText = this.innerText;
                this.disabled = true;
                this.innerText = 'Testando...';
                try {
                    const response = await fetch('/Integrations/TestGlpi', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            environment: this.dataset.environment,
                            baseUrl: field('BaseUrl'),
                            appToken: field('AppToken'),
                            userToken: field('UserToken'),
                            classificationFieldKey: field('ClassificationFieldKey'),
                            devOpsUrlFieldKey: field('DevOpsUrlFieldKey')
                        })
                    });
                    const data = await response.json().catch(() => ({ message: 'Não foi possível ler a resposta do servidor.' }));
                    const warnings = Array.isArray(data.warnings) && data.warnings.length ? `\n\n${data.warnings.join('\n')}` : '';
                    Swal.fire({
                        text: `${data.message || 'Teste concluído.'}${data.glpiVersion ? `\nGLPI ${data.glpiVersion}` : ''}${warnings}`,
                        icon: response.ok ? 'success' : 'error',
                        buttonsStyling: false,
                        confirmButtonText: 'Ok',
                        customClass: { confirmButton: response.ok ? 'btn btn-primary' : 'btn btn-danger' }
                    });
                } catch {
                    Swal.fire({ text: 'Erro de comunicação com o servidor.', icon: 'error', buttonsStyling: false, confirmButtonText: 'Ok', customClass: { confirmButton: 'btn btn-danger' } });
                } finally {
                    this.disabled = false;
                    this.innerText = originalText;
                }
            });
        });
    </script>
}
